ount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1145","messages":"1146","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1147","messages":"1148","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1149","messages":"1150","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1151","usedDeprecatedRules":"573"},{"filePath":"1152","messages":"1153","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1154","messages":"1155","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1156","usedDeprecatedRules":"586"},{"filePath":"1157","messages":"1158","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1159","usedDeprecatedRules":"573"},{"filePath":"1160","messages":"1161","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1162","usedDeprecatedRules":"573"},{"filePath":"1163","messages":"1164","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1165","usedDeprecatedRules":"573"},{"filePath":"1166","messages":"1167","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1168","messages":"1169","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1170","messages":"1171","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1172","messages":"1173","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1174","messages":"1175","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1176","messages":"1177","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1178","messages":"1179","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1180","messages":"1181","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1182","messages":"1183","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1184","messages":"1185","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1186","messages":"1187","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1188","messages":"1189","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1190","messages":"1191","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1192","messages":"1193","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1194","usedDeprecatedRules":"573"},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1195","1196","1197","1198"],"import general from \"./general\";\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from \"./class-changes\";\nimport factions from \"./factions\";\nimport professions from \"./professions\";\nimport itemization from \"./itemization\";\nimport raceChanges from \"./race-changes\";\nimport designGoals from \"./design-goals\";\n// import phases from './phases'\n\nexport default {\n  title: \"Patch notes\",\n  sections: [\n    designGoals,\n    general,\n    classChanges,\n    raceChanges,\n    // factions,\n    // itemization,\n    // professions,\n  ],\n};\n",["1199","1200"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1201","1202","1203","1204"],"import world from \"./general/world\";\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from \"./general/server-balance\";\nimport worldBuffs from \"./general/world-buffs\";\nimport miscellaneous from \"./general/miscellaneous\";\n\nexport default {\n  title: \"General\",\n  content: [miscellaneous],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1205"],"export default {\n  title: \"Miscellaneous\",\n  content: [\n    \"Hit chance now applies to both to both spells and physical attacks unless otherwise specified.\",\n    \"Crit chance now applies to both to both spells and physical attacks unless otherwise specified.\",\n    \"Buff and debuff limit removed.\",\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    \"Quest log size increased.\",\n    \"Normal, elite and boss target dummies have been added to all major cities.\",\n    \"All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.\",\n    \"A disenchant option has been added to the need/greed UI.\",\n    \"The character pane now contains additional information like hit and crit.\",\n    \"Mail between characters on the same account is now instant.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Throwing weapons now often also increase the user's stats.\",\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n    \"Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.\",\n    \"Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1206"],"export default {\n  title: \"Warlock\",\n  content: [\n    \"New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone.\",\n    \"New ability: Soulshatter: Reduces threat by 50% for all enemies within 40 yards. Reagents: Soul Shard. 5 min cooldown.\",\n    \"New ability: Incinerate: Deals Fire damage to your target and additional Fire damage if the target is affected by an Immolate spell.\",\n    \"Firestone bonus Fire damage is increased and now add fire damage to the Warlock's Wand attacks.\",\n    \"The Warlock now only takes 50% of the damage caused by Hellfire.\",\n    \"Increased the health gained from Demon Armor.\",\n    \"Curse of Weakness now reduces the target's damage done by 5%. Only one rank available.\",\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    \"Increased Soul Shards stack size.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1207"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1208","1209"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1210"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1211"],"export default {\n  title: \"Warrior\",\n  content: [\n    \"New ability: Victory Rush: Instantly attack the target causing damage. Can only be used within 20 sec after you kill an enemy that yields experience or honor. Damage is based on your attack power.\",\n    \"New ability: Stance Mastery: You retain up to 10 rage points when you change stances.\",\n    \"Thunder Clap can now be used in defensive stance.\",\n    \"Slam can now be cast while moving and ignores pushback caused by damage.\",\n    \"Increased the time required for your rage to decay while out of combat 30%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1212"],"export default {\n  title: \"Priest\",\n  content: [\n    \"Increased the damage over time of Holy Fire.\",\n    \"Damage absorbed by Power Word: Shield now scales with spell healing.\",\n    \"Fear Ward is now available to all races. Cooldown increased to 3 minutes, last 3 minutes. Fear Ward is now a discipline spell.\",\n    \"Feedback (Human) reduced mana cost and increased effect.\",\n    \"Chastise (Dwarf): new spell: Deals Holy damage and immoblizes the target, causing low theat. 20 yd range, 30 sec cooldown.\",\n    \"Elune’s Grace (Night Elf) now reduces the chance you are hit by melee or ranged attacks by 25% for 15 sec.\",\n    \"Starshards (Night Elf) now deals increased damage and lasts 4 sec. 1 min cooldown.\",\n    \"Shadowguard (Troll) orbs now look like shadow orbs instead of lightning.\",\n    \"Reduced the mana cost of Power Word: Fortitude, Prayer of Fortitude, Shadow Protection, Prayer of Shadow Protection, Divine Spirit and Prayer of Spirit.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1213"],"export default {\n  title: \"Tauren\",\n  content: [\n    \"New ability: Brawn: Increases critical strike damage and healing by 5%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1214"],"export default {\n  title: \"Druid\",\n  content: [\n    \"New ability: Lacerate: Lacerates the enemy target, dealing bleed damage over 15 sec and causing a high amount of threat. Damage increased by attack power. This effect stacks up to 5 times on the same target. Costs 15 rage and requires Bear Form or Dire Bear Form.\",\n    \"Tiger’s Fury reworked: now returns 50 energy and increases the damage of your next ability while in cat form by 25%. 30 sec cooldown.\",\n    \"Faerie Fire no longer costs mana, now has a 6 second cooldown and can be used in all forms.\",\n    \"Cat Form now has a separate action bar when prowling.\",\n    \"Nature's Grasp and Entangling Roots can now be cast while inside.\",\n    \"Barkskin now reduces all damage taken by 25%, no longer reduces cast time and attack speed, and can be cast while frozen, incapacitated or feared. Cooldown is increased to 2 min.\",\n    \"Swipe now scales with attack power.\",\n    \"Tranquility no longer causes threat.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    \"Rejuvenation and Regrowth spells can now be active on targets affected by another Druid's Rejuvenation or Regrowth.\",\n    \"Reduced the mana cost of Mark of the Wild and Gift of the Wild.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1215"],"export default {\n  title: \"Paladin\",\n  content: [\n    \"New ability: Hand of Reckoning: Taunts the target to attack you. 10 sec cooldown.\",\n    \"Consecration is now a baseline ability.\",\n    \"Judgement no longer costs mana.\",\n    \"Exorcism and Holy Wrath can now be cast against any target, but always critical hit against Undead and Demon targets.\",\n    \"Seal of the Crusader reworked: Now increases attack speed by 30% and causes your attacks to deal Holy damage. Judgement effect stays the same.\",\n    \"Seal of Justice effect now stuns up to two nearby enemies.\",\n    \"Judgement of Justice now also caps the target’s movement speed at 100%.\",\n    \"Blessing of Might now also increases ranged attack power.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1216"],"export default {\n  title: \"Shaman\",\n  content: [\n    \"New ability: Totemic Recall: Removes all your totems and returns mana equal to 25% of their cost.\",\n    \"Searing Totem now only attacks enemies that are in combat with the Shaman.\",\n    \"Chain Lightning and Lightning Bolt cast time reduced by 0.5 sec.\",\n    \"Increased the slow effect of Frostbrand Weapon to 50%.\",\n    \"Flametongue, Frostbrand, Rockbiter and Windfury Weapon effects and Flametongue and Windfury Totem effects are now catagorized as generic buffs instead of weapon buffs.\",\n    \"Flametongue, Frostbrand, Rockbiter and Windfury Weapon effects should now deal similar damage.\",\n    \"Flametongue and Windfury Totems should now deal similar damage.\",\n    \"Increased the radius of totems that affect friendly targets to 30 yards.\",\n    \"Sentry Totem now has stealth.\",\n    \"Stoneskin Totem now also reduces damage taken from ranged attacks.\",\n    \"Windwall Totem has been removed.\",\n    \"Stoneclaw Totem now has health equal to 20% of the Shaman’s health and has a 50% chance to stun enemies that attack it.\",\n    \"Shamans now retain their weapon skills when they unlearn Two-Handed Axes and Two-Handed Maces by changing talents.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1217"],"import { Item } from './Classes'\n\nexport default [\n  new Item('Libram of Wrath', 'inv_misc_book_07', 'epic', 'Relic', 'Libram', null, null, null, null, ['Allows your Hammer of Wrath to be cast on targets with any amount of health, but reduces the damage by 95%.']),\n  new Item('Totem of Tempest', 'inv_jewelry_amulet_06', 'epic', 'Relic', 'Totem', null, null, null, null, ['Reduces the threat of additional attacks from your Windury Weapon by 75%.']),\n  new Item('Band of Guidance', 'inv_jewelry_ring_43', 'epic', 'Finger', null, null, null, null, null, ['Equip: Increases your chance to hit by 2%.', 'Equip: Increases your chance to hit with spells by 2%.']),\n  new Item('Daybreak', 'inv_hammer_04', 'epic', 'Two-hand', 'Mace', 'Speed 3.00', '131 - 255 Damage', '(59.33 damage per second)', null, ['Chance on hit: physical damage taken by target increased by 10% for 8 sec.']),\n  new Item('Idol of the World Tree', 'inv_qirajidol_night', 'rare', 'Relic', 'Idol', null, null, null, null, ['Increases the duration of your Rejuvenation and Regrowth spells by 4 sec.']),\n  new Item('Jewel of Synergy', 'inv_jewelry_ring_64', 'epic', 'Trinket', null, null, null, null, null, ['Increases your spell damage by 10% for 8 sec after dealing damage from three different magic schools within 3 sec.']),\n  new Item('Book of Command', 'warlock_grimoireofcommand', 'epic', 'Trinket', null, null, null, null, null, ['Use: Increases the damage and critical strike chance of your active pets and summons by 25% for 15 sec. (3 min cooldown)']),\n  // new Item('Totem of Tidal Orbs', 'inv_qirajidol_life', 'epic', 'Relic', 'Totem', null, null, null, null, ['Damage from your Lightning Shield returns mana equal to 60% of the damage dealt.']),\n  // new Item(\n  //   'Breastplate of Victory',\n  //   'inv_chest_plate07',\n  //   'rare',\n  //   'Chest',\n  //   'Mail',\n  //   null,\n  //   null,\n  //   null,\n  //   { armor: 207, stamina: 0, strength: 0, intellect: 0, spirit: 0, agility: 0 },\n  //   ['Gain 10 rage and 10% health after killing an opponent that yields experience or honor.'],\n  //   'Warrior',\n  //   27\n  // ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1218"],"export default {\n  title: \"Mage\",\n  content: [\n    \"New ability: Arcane Blast: Blasts the target with energy, dealing Arcane damage. Each time you cast Arcane Blast, the casting time is reduced while mana cost is increased. Effect stacks up to 3 times and lasts 8 sec.\",\n    \"New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits.\",\n    \"Ice Block is now a baseline ability.\",\n    \"Amplify magic reworked: Increases spell damage taken by up to 5 enemies in target area by 30% for 10 sec. 2 sec cast, 5 min cooldown.\",\n    \"Dampen Magic reworked: Reduces spell damage taken by up to 5 party or raid members in target area by 30% for 10 sec. 2 sec, 5 min cooldown.\",\n    \"Reduced the mana cost of Arcane Intellect and Arcane Brilliance.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1219"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1220"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1221"],"export default {\n  title: \"Itemization\",\n  note: \"\",\n  content: [\n    \"Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.\",\n    \"Existing class sets have been reworked to better fit their class and spec.\",\n    \"Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1222"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1223"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1224"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Untamed\",\n    \"spell_nature_dryaddispelmagic\",\n    [\n      \"Increases your Arcane, Fire and Nature damage by up to \",\n      \"% of your attack power.\",\n    ],\n    5,\n    [[10, 20, 30, 40, 50]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Deflection\",\n    \"ability_parry\",\n    [\"Increases your parry chance by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1225"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Wyvern Sting\",\n    \"inv_spear_02\",\n    [\n      \"A stinging shot that puts the target to sleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the Sting causes 300 Nature damage over 6 sec. Only one Sting per Hunter can be active on the target at a time.\",\n    ],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    \"115 Mana\",\n    \"8 - 35 yd range\",\n    \"Instant\",\n    \"1 min cooldown\",\n    null,\n    { isNew: false, isChanged: true, isMoved: false }\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["1226"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Ferocious Inspiration\",\n    \"ability_hunter_ferociousinspiration\",\n    [\n      \"When your pet scores a critical hit, all party members have their damage increased by \",\n      \"% and all party members' pets and summons have their damage increased by \",\n      \"% for 10 sec.\",\n    ],\n    3,\n    [\n      [1, 2, 3],\n      [3, 6, 9],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent(\n    \"Frenzy\",\n    \"inv_misc_monsterclaw_03\",\n    [\n      \"Gives your pet a \",\n      \"% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.\",\n    ],\n    5,\n    [[20, 40, 60, 80, 100]],\n    [{ x: 3, y: 2 }]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1227"],"export default {\n  title: \"Hunter\",\n  content: [\n    \"New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing your ranged and melee auto attacks to regenerate mana but reducing your total damage done by 10%.  In addition, you gain 10% of maximum mana every 3 sec. Mana gained is based on the speed of your weapon. Only one Aspect can be active at a time.\",\n    \"New ability: Steady Shot: A steady shot that causes 100% ranged weapon damage.\",\n    \"Mongoose Bite now also activates after the hunter lands a melee critical strike.\",\n    \"Aspect of the Beast reworked: now also increases the melee attack power of the hunter and the hunter's pet by 10%.\",\n    \"Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.\",\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master's attack power.\",\n    \"Number of stable slots increased.\",\n    \"Traps can be set while in combat, but require a 2 second arming time.\",\n    \"Auto shot will be automatically enabled if the Hunter steps out of melee range while in combat with target.\",\n    \"1 Agility will now grant 1 ranged and melee attack power.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1228"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Bow Specialization\",\n    \"inv_weapon_bow_03\",\n    [\n      \"Gives you a \",\n      \"% chance to trigger an additional attack against the same target when using bows.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Crossbow Specialization\",\n    \"inv_weapon_crossbow_04\",\n    [\"Increases your attack speed with Crossbows by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Gun Specialization\",\n    \"inv_weapon_rifle_02\",\n    [\n      \"Increases your critical strike chance and critical strike damage with Guns by \",\n      \"%.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1229"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Barrage\",\n    \"ability_upgrademoonglaive\",\n    [\n      \"Increases the damage done by your Multi-Shot and Volley spells by \",\n      \"%.\",\n    ],\n    3,\n    [[5, 10, 15]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Scatter Shot\",\n    \"ability_golemstormbolt\",\n    [\n      \"A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.\",\n    ],\n    1,\n    [[]],\n    null,\n    null,\n    \"8% of base mana\",\n    \"15 yd range\",\n    \"30 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1230"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1231"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Survival of the Fittest\",\n    \"ability_hunter_mastertactitian\",\n    [\n      \"When you deal Arcane, Fire or Nature damage with one of your abilities, you have a \",\n      \"% chance to reduce the cooldown of all party members' abilities by 1 sec.\",\n    ],\n    2,\n    [[10, 20]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isChanged: false,\n      isMoved: false,\n      isNew: true,\n    }\n  ),\n  new Talent(\n    \"Killer Instinct\",\n    \"spell_holy_blessingofstamina\",\n    [\"Increases your critical strike chance with all attacks by \", \"%.\"],\n    3,\n    [[1, 2, 3]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Counterattack\",\n    \"ability_warrior_challange\",\n    [\n      \"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\",\n    ],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    \"45 Mana\",\n    \"Melee range\",\n    \"Instant\",\n    \"5 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1232"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1233"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Trap Mastery\",\n    \"spell_nature_timestop\",\n    [\n      \"Increases the duration of your Freezing and Frost traps by \",\n      \"% and the damage of your Explosive and Immolations traps by \",\n      \"%. In addition, reduces the chance your traps are resisted by \",\n      \"% and reduces the time to arm traps by \",\n      \" sec.\",\n    ],\n    2,\n    [\n      [15, 30],\n      [15, 30],\n      [5, 10],\n      [0.5, 1],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Survivalist\",\n    \"spell_shadow_twilight\",\n    [\"Increases total health by \", \"%.\"],\n    5,\n    [[2, 4, 6, 8, 10]]\n  ),\n  new Talent(\n    \"Deterrence\",\n    \"ability_whirlwind\",\n    [\"When activaed, increases dodge and parry chance by 25% for 10 sec.\"],\n    1,\n    [[]],\n    [{ x: null, y: null }],\n    [{ x: 4, y: 2 }],\n    null,\n    null,\n    \"Instant\",\n    \"5 min cooldown\",\n    [\"D2\"]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1234"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Improved Stings\",\n    \"spell_nature_nullifypoison\",\n    [\"Increases the effect of your Stings by \", \"%.\"],\n    3,\n    [[3, 6, 9]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Swift Shots\",\n    \"ability_hunter_zenarchery\",\n    [\"Your Arcane Shot reduces the cooldown of your Rapid Fire by \", \" sec.\"],\n    2,\n    [[1, 2]],\n    [{ x: 0, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Lethal Shots\",\n    \"ability_searingarrow\",\n    [\"Increases your critical strike chance with ranged weapons by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]],\n    [{ x: null, y: null }],\n    [{ x: 2, y: 2 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D1\"]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1235"],"import React, { useState } from \"react\";\nimport { useHistory, useLocation, useParams } from \"react-router-dom\";\n\nimport SelectWrapper from \"./talent-calculator-select\";\nimport TalentCalculatorMain from \"./talent-calculator-main/\";\nimport styles from \"./index.module.css\";\nimport ChangedSelect from \"./changed-select\";\nimport { PlayerClassParam, URLParams } from \"../../types\";\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>();\n  const history = useHistory();\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`);\n  };\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true);\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true);\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true);\n\n  const toggleIsNew = () => setIsNew(!displayIsNew);\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged);\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved);\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  };\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  };\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect\n        toggleChangedObj={toggleChangedObj}\n        displayChanged={displayChanged}\n      />\n      <TalentCalculatorMain\n        displayChanged={displayChanged}\n        selectedClass={playerClass}\n      />\n    </div>\n  );\n};\n\nexport default TalentCalculator;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1236"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier1.ts",["1237"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Improved Aspect of the Hawk\",\n    \"spell_nature_ravenform\",\n    [\n      \"While Aspect of the Hawk is active, all normal ranged attacks have a \",\n      \"% chance to increase your ranged attack speed by 30% for 12 sec.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  new Talent(\n    \"Improved Aspect of the Beast\",\n    \"ability_mount_pinktiger\",\n    [\n      \"While Aspect of the Beast is active, critical strikes from your pet's abilities increase your melee attack speed by \",\n      \"% for 8 sec.\",\