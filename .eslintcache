tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/tooltip.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/paragraph.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/grid/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier7.ts",["1235"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-main/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/single-item.tsx",["1236"],"import React from \"react\";\n\nimport { Item } from \"../../data/example-items/Classes\";\nimport { getClassColor } from \"../../lib/ui-utils\";\nimport { PlayerClassParam, Stats } from \"../../types\";\nimport styles from \"./index.module.css\";\n\nconst SingleItemIcon: React.FC<{ img: string }> = ({ img }) => {\n  return (\n    <div className={styles.singleItemIconWrapper}>\n      <div\n        className={styles.singleItemHighlight}\n        style={{\n          backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border-large.png\")`,\n        }}\n      />\n      <div\n        className={styles.singleItemIcon}\n        style={{\n          background: `url(\"https://wow.zamimg.com/images/wow/icons/large/${img}.jpg\") 0 0 no-repeat`,\n        }}\n      />\n      <div />\n    </div>\n  );\n};\n\nconst ItemName: React.FC<{ name: string; quality: string }> = ({\n  name,\n  quality,\n}) => {\n  const color = quality === \"epic\" ? \"#a335ee\" : \"#0070dd\";\n  return (\n    <div className={styles.itemName} style={{ color }}>\n      {name}\n    </div>\n  );\n};\n\nconst ItemSlot: React.FC<{\n  slot: string;\n  itemType: string | null | undefined;\n}> = ({ slot, itemType }) => {\n  return (\n    <div className={styles.singleItemFlex}>\n      <div>{slot}</div>\n      <div>{itemType}</div>\n    </div>\n  );\n};\n\nconst ItemDmg: React.FC<{\n  damage: string | null | undefined;\n  speed: string | null;\n  dps: string | null;\n}> = ({ damage, speed, dps }) => {\n  return (\n    <>\n      <div className={styles.singleItemFlex}>\n        <div>{speed}</div>\n        <div>{damage}</div>\n      </div>\n      <div className={styles.singleItemFlex}>{dps}</div>\n    </>\n  );\n};\n\nconst SingleStat: React.FC<{ stat: string; value: number }> = ({\n  stat,\n  value,\n}) => {\n  const sign = value < 0 ? \"-\" : \"+\";\n  const capitalKey = stat?.charAt(0).toUpperCase() + stat?.slice(1);\n\n  return (\n    <div className={styles.singleItemFlex}>\n      {sign}\n      {value} {capitalKey}\n    </div>\n  );\n};\n\nconst ItemStats: React.FC<{ stats: Stats }> = ({ stats }) => {\n  return (\n    <>\n      {Object.entries(stats).map(([stat, value], index) => {\n        if (!!value)\n          return <SingleStat key={index} stat={stat} value={value} />;\n      })}\n    </>\n  );\n};\n\nconst SingleItem: React.FC<Item> = ({\n  name,\n  img,\n  quality,\n  slot,\n  itemType,\n  damage,\n  speed,\n  dps,\n  stats,\n  description,\n  playerClass,\n  levelRequired,\n}) => {\n  const hasDmg = damage && speed && dps;\n\n  return (\n    <div className={styles.singleItemWrapper}>\n      <SingleItemIcon img={img} />\n      <div\n        className={styles.singleItemDescription}\n        style={{\n          backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/background/tooltip.png\")`,\n        }}\n      >\n        <ItemName name={name} quality={quality} />\n        <ItemSlot slot={slot} itemType={itemType} />\n        {hasDmg && <ItemDmg damage={damage} speed={speed} dps={dps} />}\n        {stats && <ItemStats stats={stats} />}\n        {playerClass && (\n          <div className={styles.singleItemPlayerClass}>\n            Classes:{\" \"}\n            <span\n              style={{\n                color: getClassColor(\n                  playerClass.toLowerCase() as PlayerClassParam\n                ),\n              }}\n            >\n              {playerClass}\n            </span>\n          </div>\n        )}\n        <div className={styles.itemDescription}>\n          {description &&\n            description.map((line, i) => <div key={i}>{line}</div>)}\n        </div>\n        {levelRequired && (\n          <div className={styles.singleItemPlayerClass}>\n            Requires level {levelRequired}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n};\n\nexport default SingleItem;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/index.tsx",["1237"],"import React, { useState } from 'react'\n\nimport { Talent } from '../../../data/talents/Classes'\nimport Tooltip from './tooltip'\nimport Arrow from './arrow'\nimport styles from './cell.module.css'\nimport ChangedBar from './changed-bar'\nimport { useParams } from 'react-router-dom'\nimport { URLParams } from '../../../types'\n\ninterface CellProps {\n  cellData: Talent\n  i: number\n  x: number\n  y: number\n  color: string | null\n  clickHandler: (i: number, x: number, y: number, e: React.MouseEvent<HTMLElement>) => void\n  displayChanged: {\n    displayIsNew: boolean\n    displayIsChanged: boolean\n    displayIsMoved: boolean\n  }\n}\n\nconst Cell: React.FC<CellProps> = ({ cellData, i, x, y, color, clickHandler, displayChanged }) => {\n  const { talentPoints } = useParams<URLParams>()\n  const [showTooltip, set_showTooltip] = useState<boolean>(false)\n  const { value, maxValue, icon, manaCost, range, castTime, cooldown, name, arrows, changed } = cellData\n\n  const borderColor = !!color ? `2px solid ${color}` : `2px solid black`\n  const cellFilter = !color ? 'grayscale(100%)' : 'none'\n\n  // yes: value\n\n  return (\n    <div\n      className={styles.cellWrapper}\n      onMouseEnter={() => {\n        set_showTooltip(true)\n      }}\n      onMouseLeave={() => {\n        set_showTooltip(false)\n      }}>\n      <ChangedBar displayChanged={displayChanged} changed={changed} />\n      <div className={styles.cellHighlight} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border.png\")` }} />\n      <div\n        style={{\n          background: `url(\"https://wow.zamimg.com/images/wow/icons/medium/${icon}.jpg\") 0 0 no-repeat`,\n          border: borderColor,\n          filter: cellFilter,\n        }}\n        className={styles.cellIconStyle}>\n        <button\n          className={styles.cellButtonStyle}\n          onClick={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}\n          onContextMenu={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}>\n          <div className={styles.cellPointsStyle} style={{ color: color ? 'white' : '#787878' }}>\n            {`${value}/${maxValue}`}\n          </div>\n        </button>\n      </div>\n      {showTooltip && <Tooltip value={cellData.value} description={cellData.description} maxValue={cellData.maxValue} valueIteration={cellData.valueIteration} manaCost={manaCost} range={range} castTime={castTime} cooldown={cooldown} name={name} />}\n      {arrows &&\n        arrows.map((arrow, i) => {\n          return <Arrow arrowData={arrow} color={color} key={i} />\n        })}\n    </div>\n  )\n}\n\nexport default Cell\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/night-elf.tsx",["1238"],"export default {\n  title: \"Night Elf\",\n  content: [\n    \"New ability: Elusiveness: Increases stealth level by 1 and movement speed while stealthed by 5%.\",\n    \"Shadowmeld no longer increases stealth level.\",\n    \"Quickness now also increase attack speed by 1%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/orc.tsx",["1239"],"export default {\n  title: 'Orc',\n  content: ['Blood Fury: now also increases your spell damage and healing and ranged attack power.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/ui-utils.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/talents-url.tsx",["1240","1241"],"import { Talent } from '../data/talents/Classes'\nimport { ClassSpecType, ClassTalentType } from '../types'\n\nconst flattenSpec = (specData: ClassSpecType) => {\n  return specData.flatMap(row => row)\n}\n\nexport const flattenTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return talentData.flatMap(flattenSpec)\n}\n\nexport const getFlattenedTalentValues = (talentData: ClassTalentType | null) => {\n  const flattenedTalents = flattenTalents(talentData)\n  return flattenedTalents.map(talent => talent?.value).filter(talent => !isNaN(talent!))\n}\n\nconst getTruthyTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return flattenTalents(talentData).filter(talent => talent)\n}\n\nconst loopURLTalents = (flatTalents: (Talent | null)[], talentsFromUrl: string) => {\n  let stringIndex: number = 0\n\n  for (let i = 0; i < flatTalents.length; i++) {\n    if (!!flatTalents[i]) {\n      flatTalents[i]?.setValue(parseInt(talentsFromUrl[stringIndex]))\n      stringIndex++\n    }\n  }\n}\n\n// http://localhost:3000/tc-ts#/tc/druid/0140003000000000050023011000000000055003115010000\n\nexport const loopTalentsFromUrl = (talentData: ClassTalentType | null, talentPoints: string) => {\n  if (!talentData) return []\n\n  let stringIndex: number = 0\n\n  talentData.forEach(spec => {\n    spec.forEach(row => {\n      row.forEach(cell => {\n        if (!!cell) {\n          cell.setValue(parseInt(talentPoints[stringIndex]))\n          stringIndex++\n        }\n      })\n    })\n  })\n\n  return talentData\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-footer/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/professions/index.ts",["1242"],"export default {\n  title: 'Professions',\n  note: '',\n  content: [\n    'Players can now select their profession and rank as title. For example “Artisan Blacksmith [Name]”.',\n    'Many profession quests have been added.',\n    'Various new recipes have been added. Many crafting professions should generally offer stronger options for both endgame and leveling content.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/index.ts",["1243"],"import dwarf from \"./race-changes/dwarf\";\nimport gnome from \"./race-changes/gnome\";\nimport human from \"./race-changes/human\";\nimport nightElf from \"./race-changes/night-elf\";\nimport orc from \"./race-changes/orc\";\nimport tauren from \"./race-changes/tauren\";\nimport troll from \"./race-changes/troll\";\nimport undead from \"./race-changes/undead\";\n\nexport default {\n  title: \"Race changes\",\n  content: [human, dwarf, gnome, nightElf, orc, troll, tauren, undead],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter-pets.ts",["1244"],"export default {\n  title: \"Hunter pets\",\n  content: [\n    \"Bears can now also learn Swipe, which deals mediocre damage in a frontal cone.\",\n    \"Crocolisks, Hyenas and Raptors can now learn Crushing Jaw, which has a 100% crit chance and 25 sec cooldown.\",\n    \"Spiders can now also learn Spider Poison, which has the same effect as Scorpid Poison.\",\n    \"Crabs can now also learn Shell Shield.\",\n    \"Tallstriders can now also learn Screech.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/index.tsx",["1245"],"import druid from \"./classes/druid\";\nimport hunter from \"./classes/hunter\";\nimport hunterPets from \"./classes/hunter-pets\";\nimport mage from \"./classes/mage\";\nimport paladin from \"./classes/paladin\";\nimport priest from \"./classes/priest\";\nimport rogue from \"./classes/rogue\";\nimport shaman from \"./classes/shaman\";\nimport warlock from \"./classes/warlock\";\n// import warlockDemons from './classes/warlock-demons'\nimport warrior from \"./classes/warrior\";\n\nexport default {\n  title: \"Class changes\",\n  content: [\n    druid,\n    hunter,\n    hunterPets,\n    mage,\n    paladin,\n    priest,\n    rogue,\n    shaman,\n    warlock,\n    warrior,\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/design-goals/index.tsx",["1246"],"export default {\n  title: \"Design goals\",\n  note: \"These suggested changes aim to improve diversity and give players additional ways to engage with the game. Some core design goals are listed below.\",\n  content: [\n    {\n      content: [\n        \"Diversity and variety! Expand on ways in which classes can be played, without changing them fundamentally.\",\n        \"Focus on class design and some QoL. Leave content, professions and itemization to people with better ideas.\",\n        \"Each spec should be great to have in a group, while none should be mandatory.\",\n        \"Each spec, and each race/class combination should have its place in both PvE and PvP.\",\n        \"Each spec gets something new. Some specs need more than others.\",\n        \"Healers should be more independent and able to grind mobs and resources more easily.\",\n        \"Adjust useless or boring talents and abilities.\",\n        \"All while staying true to the classic fantasy and mechanics and leaning into the uniqueness of each class and spec.\",\n      ],\n    },\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.tsx",["