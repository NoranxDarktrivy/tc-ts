new Talent('Ferocity', 'inv_misc_monsterclaw_04', ['Increases the critical strike chance of your pets by ', '%.'], 5, [[3, 6, 9, 12, 15]], [{ x: null, y: null }], [{ x: 5, y: 2 }], null, null, null, null, ['D2']),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier3.ts",["1151"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/reportWebVitals.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/human.tsx",["1152"],"export default {\n  title: 'Human',\n  content: ['New ability: Kirin Tor Legacy: Mana gained from all sources increased by 3%.', 'Mace Specialization removed.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/server-balance.ts",["1153"],"export default {\n  title: 'Server Balance',\n  content: [\n    'On servers where one faction is underrepresented, players of that faction gain bonus experience and reputation in proportion to this underrepresentation. This should encourage players to choose servers and factions with population issues.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier2.ts",[],"/Users/d