,{"filePath":"1162","messages":"1163","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1164","messages":"1165","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1166","messages":"1167","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1168","messages":"1169","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1170","messages":"1171","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1172","messages":"1173","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1174","messages":"1175","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1176","messages":"1177","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1178","usedDeprecatedRules":"573"},{"filePath":"1179","messages":"1180","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1181","1182","1183","1184"],"import general from \"./general\";\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from \"./class-changes\";\nimport factions from \"./factions\";\nimport professions from \"./professions\";\nimport itemization from \"./itemization\";\nimport raceChanges from \"./race-changes\";\nimport designGoals from \"./design-goals\";\n// import phases from './phases'\n\nexport default {\n  title: \"Patch notes\",\n  sections: [\n    designGoals,\n    general,\n    classChanges,\n    raceChanges,\n    // factions,\n    // itemization,\n    // professions,\n  ],\n};\n",["1185","1186"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1187","1188","1189","1190"],"import world from \"./general/world\";\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from \"./general/server-balance\";\nimport worldBuffs from \"./general/world-buffs\";\nimport miscellaneous from \"./general/miscellaneous\";\n\nexport default {\n  title: \"General\",\n  content: [miscellaneous],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1191"],"export default {\n  title: \"Miscellaneous\",\n  content: [\n    \"Hit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Crit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Buff and debuff limit removed.\",\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    \"Quest log size increased.\",\n    \"Normal, elite and boss target dummies have been added to all major cities.\",\n    \"All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.\",\n    \"A disenchant option has been added to the need/greed UI.\",\n    \"The character pane now contains additional information like hit and crit.\",\n    \"Mail between characters on the same account is now instant.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Throwing weapons now often also increase the user's stats.\",\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n    \"Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.\",\n    \"Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1192"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1193"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1194","1195"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1196"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1197"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1198"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/t