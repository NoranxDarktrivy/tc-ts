ges":"996","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"997","messages":"998","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"999","messages":"1000","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"505"},{"filePath":"1001","messages":"1002","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1003","messages":"1004","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1005","messages":"1006","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1007","messages":"1008","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1009","messages":"1010","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1011","messages":"1012","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1013","messages":"1014","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"505"},{"filePath":"1015","messages":"1016","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1017","messages":"1018","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1019","messages":"1020","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1021","messages":"1022","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1023","messages":"1024","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1025","messages":"1026","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1027","messages":"1028","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1029","messages":"1030","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1031","messages":"1032","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1033","messages":"1034","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1035","messages":"1036","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1037"],"import general from './general'\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from './class-changes'\nimport factions from './factions'\nimport professions from './professions'\nimport itemization from './itemization'\nimport raceChanges from './race-changes'\n// import phases from './phases'\n\nexport default {\n  title: 'Patch notes',\n  sections: [general, classChanges, raceChanges, factions, itemization, professions],\n}\n",["1038","1039"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1040"],"import world from './general/world'\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from './general/server-balance'\nimport worldBuffs from './general/world-buffs'\nimport miscellaneous from './general/miscellaneous'\n\nexport default {\n  title: 'General',\n  note: 'The main goal of these proposed changes is to add diversity to World of Warcraft Classic, without trying to reinvent the game that we know and love. All QoL changes that are found in modern classic HC, as well as the new honor system are included.',\n  content: [world, serverBalance, worldBuffs, miscellaneous],\n}\n",["1041","1042"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1043"],"export default {\n  title: 'Miscellaneous',\n  content: [\n    'Hit and spell hit are now one stat. Crit and spell crit are now one stat.',\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    'Quest log size increased to 30.',\n    'New class quests have been added.',\n    'Normal, elite and boss target dummies have been added to all major cities. Attacking these dummies does not increase weapon skill.',\n    'All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.',\n    \"New titles have been added: [City] Ambassador [Name] for exalted city reputation; [Name], The Explorer for uncovering all of Azeroth; [Rank] [Profession] [Name]; [Name] the Exalted for exalted reputation at all of your faction's capital cities.\",\n    'A disenchant option has been added to the need/greed UI.',\n    'World bosses now spawn more frequently and have improved loot tables.',\n    'The character pane now contains additional information like hit and crit.',\n    'Mail between characters on the same account is now instant.',\n    'The Troll weapon trainer now trains daggers.',\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n    'Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.',\n    'Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1044"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1045"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1046"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1047"],"export default {\n  title: 'Warrior',\n  content: [\n    'New ability: Victory Rush: Instantly attack the target causing damage. Can only be used within 20 sec after you kill an enemy that yields experience or honor. Damage is based on your attack power. Learned at lvl 10.',\n    'New ability: Stance Mastery: You retain up to 10 rage points when you change stances. Learned at lvl 20.',\n    'Thunder Clap can now be used in defensive stance.',\n    'Slam can now be cast while moving and ignores pushback caused by damage.',\n    'Increased the time required for your rage to decay while out of combat 30%.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],["1048","1049"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],["1050","1051"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],["1052","1053"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1054"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1055"],"export default {\n  title: 'Tauren',\n  content: ['New ability: Brawn: Increases critical strike damage and healing by 3%.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],["1056","1057"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],["1058","1059"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],["1060","1061"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1062"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],["1063","1064"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1065"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1066"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],["1067","1068"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1069"],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1070"],"export default {\n  title: 'Mage',\n  content: [\n    'New ability: Arcane Blast: Blasts the target with energy, dealing Arcane damage. Each time you cast Arcane Blast, the casting time is reduced while mana cost is increased. Effect stacks up to 3 times and lasts 8 sec. Learned at lvl 24.',\n    'New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits. Gained after completing a new level 60 quest.',\n    'Cold Snap is now a baseline ability and learned at level 20.',\n    'Amplify magic reworked: Now increases spell damage done and spell damage taken by 2%. Only one Amplify Magic can be active per mage. Lasts 30 min.',\n    'Dampen Magic reworked: Now reduces spell damage done and spell damage taken by 2%. Only one Dampen Magic can be active per mage. Lasts 30 min.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1071"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n",["1072","1073"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1074"],"export default {\n  title: 'Rogue',\n  content: [\n    \"A new Evasion rank has been added that also increases the rogue's chance to dodge ranged attacks by 25%. Learned at lvl 50.\",\n    'Damaging poisons now scale with attack power and spell damage.',\n    'Expose Armor now stacks with Sunder Armor.',\n    'Increased the value of Pick Pocketed items from rare enemies.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1075"],"export default {\n  title: 'Itemization',\n  note: '',\n  content: [\n    'Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.',\n    'Existing class sets have been reworked to better fit their class and spec.',\n    'Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.',\n    'Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.',\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],["1076","1077"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1078"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n",["1079","1080"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1081"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1082"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1083"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Wyvern Venom',\n    'spell_nature_nullifypoison',\n    ['When activated, your next succesful melee or ranged attack causes the target to fall asleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the venom causes 500 damage over 12 sec.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '115 Mana',\n    null,\n    'Instant',\n    '2 min cooldown',\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["1084"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Invigoration',\n    'ability_hunter_invigeration',\n    ['When your pet scores a critical hit with a special ability, you instantly regenerate ', '% of your maximum mana. 10 sec cooldown.'],\n    2,\n    [[5, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent('Frenzy', 'inv_misc_monsterclaw_03', ['Gives your pet a ', '% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.'], 5, [[20, 40, 60, 80, 100]], [{ x: 3, y: 2 }]),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1085"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1086"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Serpent Sting', 'ability_hunter_quickshot', ['Increases the damage done by your Serpent Sting by ', '%.'], 3, [[10, 20, 30]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Improvied Scorpid Sting', 'ability_hunter_criticalshot', ['Increases the effect of your Scorpid Sting by ', '%.'], 2, [[1, 2]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1087"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Scatter Shot',\n    'ability_golemstormbolt',\n    ['A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.'],\n    1,\n    [[]],\n    null,\n    null,\n    '8% of base mana',\n    '15 yd range',\n    '30 sec cooldown'\n  ),\n  new Talent('Barrage', 'ability_upgrademoonglaive', ['Increases the damage done by your Multi-Shot and Volley spells by ', '%.'], 3, [[5, 10, 15]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent('Improved Steady Shot', 'ability_hunter_steadyshot', ['Gives your Steady Shot hits a ', '% chance to increase the damage of your next Aimed Shot or Arcane Shot by 30%.'], 3, [[5, 10, 15]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1088"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1089"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1090"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1091"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1092"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Arcane Shot', 'ability_impalingbolt', ['Your Auto Shot hits reduce the cooldown of your Arcane Shot by ', ' sec.'], 2, [[0.25, 0.5]], null, [{ x: 2, y: 1 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Mortal Shots', 'ability_piercedamage', ['Increases your ranged critical strike damage bonus by ', '%.'], 5, [[6, 12, 18, 24, 39]], [{ x: 0, y: 2 }], null, null, null, null, null, null, { isNew: false, isChanged: false, isMoved: true }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],["1093","1094"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1095"],"import React, { useState } from 'react'\nimport { useHistory, useLocation, useParams } from 'react-router-dom'\n\nimport SelectWrapper from './talent-calculator-select'\nimport TalentCalculatorMain from './talent-calculator-main/'\nimport styles from './index.module.css'\nimport ChangedSelect from './changed-select'\nimport { PlayerClassParam, URLParams } from '../../types'\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>()\n  const history = useHistory()\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`)\n  }\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true)\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true)\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true)\n\n  const toggleIsNew = () => setIsNew(!displayIsNew)\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged)\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved)\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  }\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  }\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect toggleChangedObj={toggleChangedObj} displayChanged={displayChanged} />\n      <TalentCalculatorMain displayChanged={displayChanged} selectedClass={playerClass} />\n    </div>\n  )\n}\n\nexport default TalentCalculator\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1096"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Us