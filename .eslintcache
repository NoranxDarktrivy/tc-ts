ode/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["986"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["987"],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["988"],"export default {\n  title: 'Mage',\n  content: [\n    'New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits. Gained after completing a new level 60 quest.',\n    'Cold Snap is now a baseline ability and learned at level 20.',\n    'Amplify magic reworked: Now increases spell damage done and spell damage taken by 2%. Only one Amplify Magic can be active per mage. Lasts 30 min.',\n    'Dampen Magic reworked: Now reduces spell damage done and spell damage taken by 2%. Only one Dampen Magic can be active per mage. Lasts 30 min.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["989"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["990"],"export default {\n  title: 'Rogue',\n  content: [\n    \"A new Evasion rank has been added that also increases the rogue's chance to dodge ranged attacks by 25%. Learned at lvl 50.\",\n    'Damaging poisons now scale with attack power and spell damage.',\n    'Expose Armor now stacks with Sunder Armor.',\n    'Increased the value of Pick Pocketed items from rare enemies.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["991"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["992"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["993"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["994"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["995"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Wyvern Venom',\n    'spell_nature_nullifypoison',\n    ['When activated, your next succesful melee or ranged attack causes the target to fall asleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the venom causes 500 damage over 12 sec.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '115 Mana',\n    null,\n    'Instant',\n    '2 min cooldown',\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["996"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Invigoration',\n    'ability_hunter_invigeration',\n    ['When your pet scores a critical hit with a special ability, you instantly regenerate ', '% of your maximum mana. 10 sec cooldown.'],\n    2,\n    [[5, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent('Frenzy', 'inv_misc_monsterclaw_03', ['Gives your pet a ', '% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.'], 5, [[20, 40, 60, 80, 100]], [{ x: 3, y: 2 }]),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["997"],"export default {\n  title: 'Hunter',\n  content: [\n    'New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing your ranged and melee auto attacks to regenerate mana but reducing your total damage done by 10%.  In addition, you gain 10% of maximum mana every 3 sec.  Mana gained is based on the speed of your weapon. Only one Aspect can be active at a time. Learned at lvl 40.',\n    'New ability: Steady Shot: A steady shot that causes 100% ranged weapon damage. Learned at lvl 50.',\n    'New ability: Kill Command: Give the command to kill, causing your pet to instantly attack for additional damage. Can only be used after the Hunter lands a critical strike on the target. Learned at lvl 28.',\n    'Mongoose Bite now also activates after the hunter lands a melee critical strike.',\n    'Scorpid Sting reworked: Stings the target, reducing chance to hit with melee and ranged attacks by 3% for 20 sec. Only one Sting per Hunter can be active on any one target.',\n    'Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.',\n    'Aspect of the Beast now also greatly reduces the range at which hostile beasts will attack you and your pet.',\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s attack power.\",\n    'Stable slots increased to 5.',\n    'Traps can be set while in combat, but require a 2 second arming time.',\n    'Freezing Trap will now cancel combat when cast.',\n    'Auto shot will be automatically enabled if the Hunter steps out of melee range while in combat with target.',\n    '1 Agility will now grant 1 ranged and melee attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["998"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Serpent Sting', 'ability_hunter_quickshot', ['Increases the damage done by your Serpent Sting by ', '%.'], 3, [[10, 20, 30]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Improvied Scorpid Sting', 'ability_hunter_criticalshot', ['Increases the effect of your Scorpid Sting by ', '%.'], 2, [[1, 2]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["999"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Scatter Shot',\n    'ability_golemstormbolt',\n    ['A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.'],\n    1,\n    [[]],\n    null,\n    null,\n    '8% of base mana',\n    '15 yd range',\n    '30 sec cooldown'\n  ),\n  new Talent('Barrage', 'ability_upgrademoonglaive', ['Increases the damage done by your Multi-Shot and Volley spells by ', '%.'], 3, [[5, 10, 15]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent('Improves Steady Shot', 'ability_hunter_steadyshot', ['Gives your Steady Shot hits a ', '% chance to increase the damage of your next Aimed Shot or Arcane Shot by 15%.'], 3, [[5, 10, 15]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1000"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1001"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1002"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1003"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1004"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Arcane Shot', 'ability_impalingbolt', ['Your Auto Shot hits reduce the cooldown of your Arcane Shot by ', ' sec.'], 2, [[0.25, 0.5]], null, [{ x: 2, y: 1 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Mortal Shots', 'ability_piercedamage', ['Increases your ranged critical strike damage bonus by ', '%.'], 5, [[6, 12, 18, 24, 39]], [{ x: 0, y: 2 }], null, null, null, null, null, null, { isNew: false, isChanged: false, isMoved: true }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],["1005","1006"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1007"],"import React, { useState } from 'react'\nimport { useHistory, useLocation, useParams } from 'react-router-dom'\n\nimport SelectWrapper from './talent-calculator-select'\nimport TalentCalculatorMain from './talent-calculator-main/'\nimport styles from './index.module.css'\nimport ChangedSelect from './changed-select'\nimport { PlayerClassParam, URLParams } from '../../types'\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>()\n  const history = useHistory()\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`)\n  }\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true)\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true)\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true)\n\n  const toggleIsNew = () => setIsNew(!displayIsNew)\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged)\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved)\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  }\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  }\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect toggleChangedObj={toggleChangedObj} displayChanged={displayChanged} />\n      <TalentCalculatorMain displayChanged={displayChanged} selectedClass={playerClass} />\n    </div>\n  )\n}\n\nexport default TalentCalculator\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1008"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts