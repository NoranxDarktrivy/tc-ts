,"endColumn":2},{"ruleId":"1247","severity":1,"message":"1248","line":10,"column":1,"nodeType":"1249","endLine":14,"endColumn":2},{"ruleId":"1247","severity":1,"message":"1248","line":1,"column":1,"nodeType":"1249","endLine":11,"endColumn":2},{"ruleId":"1247","severity":1,"message":"1248","line":13,"column":1,"nodeType":"1249","endLine":17,"endColumn":2},"import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","no-native-reassign",["1270"],"no-negated-in-lhs",["1271"],"Assign array to a variable before exporting as module default","@typescript-eslint/no-unused-vars","'useLocation' is defined but never used.","Identifier","unusedVar","no-sparse-arrays","Unexpected comma in middle of array.","ArrayExpression","unexpectedSparseArray","array-callback-return","Array.prototype.map() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","'talentPoints' is assigned a value but never used.","'getTruthyTalents' is assigned a value but never used.","'loopURLTalents' is assigned a value but never used.","no-global-assign","no-unsafe-negation"]