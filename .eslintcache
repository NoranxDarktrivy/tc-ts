message":"1269","line":1,"column":1,"nodeType":"1270","endLine":9,"endColumn":2},{"ruleId":"1268","severity":1,"message":"1269","line":10,"column":1,"nodeType":"1270","endLine":13,"endColumn":3},{"ruleId":"1268","severity":1,"message":"1269","line":1,"column":1,"nodeType":"1270","endLine":10,"endColumn":3},{"ruleId":"1268","severity":1,"message":"1269","line":13,"column":1,"nodeType":"1270","endLine":27,"endColumn":3},{"ruleId":"1268","severity":1,"message":"1269","line":1,"column":1,"nodeType":"1270","endLine":18,"endColumn":3},"@typescript-eslint/no-unused-vars","'factions' is defined but never used.","Identifier","unusedVar","'professions' is defined but never used.","'itemization' is defined but never used.","import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","no-native-reassign",["1289"],"no-negated-in-lhs",["1290"],"'world' is defined but never used.","'serverBalance' is defined but never used.","'worldBuffs' is defined but never used.",["1289"],["1290"],"Assign array to a variable before exporting as module default","'useLocation' is defined but never used.","array-callback-return","Array.prototype.map() expects a value to be returned at the end of arrow function.","ArrowFunctionExpression","expectedAtEnd","'talentPoints' is assigned a value but never used.","'getTruthyTalents' is assigned a value but never used.","'loopURLTalents' is assigned a value but never used.","no-global-assign","no-unsafe-negation"]