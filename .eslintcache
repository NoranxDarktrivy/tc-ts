Count":0,"fixableWarningCount":0},{"filePath":"1073","messages":"1074","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1075","messages":"1076","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1077","messages":"1078","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1079","usedDeprecatedRules":"548"},{"filePath":"1080","messages":"1081","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1082","messages":"1083","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"548"},{"filePath":"1084","messages":"1085","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1086","messages":"1087","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"548"},{"filePath":"1088","messages":"1089","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"548"},{"filePath":"1090","messages":"1091","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1092","messages":"1093","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1094","messages":"1095","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1096","usedDeprecatedRules":"548"},{"filePath":"1097","messages":"1098","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1099","messages":"1100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1101","messages":"1102","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1103","messages":"1104","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1105"],"import general from './general'\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from './class-changes'\nimport factions from './factions'\nimport professions from './professions'\nimport itemization from './itemization'\nimport raceChanges from './race-changes'\n// import phases from './phases'\n\nexport default {\n  title: 'Patch notes',\n  sections: [general, classChanges, raceChanges, factions, itemization, professions],\n}\n",["1106","1107"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1108"],"import world from './general/world'\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from './general/server-balance'\nimport worldBuffs from './general/world-buffs'\nimport miscellaneous from './general/miscellaneous'\n\nexport default {\n  title: 'General',\n  note: 'The main goal of these proposed changes is to add diversity to World of Warcraft Classic, without trying to reinvent the game that we know and love. All QoL changes that are found in modern classic HC, as well as the new honor system are included.',\n  content: [world, serverBalance, worldBuffs, miscellaneous],\n}\n",["1109","1110"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1111"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1112"],"export default {\n  title: 'Warlock',\n  content: [\n    'New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone. Learned after completing a new level 60 quest.',\n    'New ability: Soulshatter: Reduces threat on the target by 100%. Reagents: Soul Shard. 2 min cooldown. Learned at lvl 60',\n    'New ability: Incinerate: Deals Fire damage to your target and additional Fire damage if the target is affected by an Immolate spell. Learned at lvl 54.',\n    'Firestone bonus fire spell damage increased. No longer grants attacks a chance to deal fire damage.',\n    'Spellstone now increases your spell damage by a small amount and increases hit chance by 2%.',\n    'Hellfire now deals increased damage. The Warlock now only takes 50% of the damage caused by Hellfire.',\n    'Increased the health gained from Demon Armor.',\n    \"Curse of Weakness now reduces the target's damage done by 5%. Only one rank available.\",\n    'Warlocks can now summon party and raid members from within a dungeon or raid.',\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    'Soul Shards now stack up to 20 per bag slot.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1113"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1114","1115"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1116"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n",["1117","1118"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1119"],"export default {\n  title: 'Warrior',\n  content: [\n    'New ability: Victory Rush: Instantly attack the target causing damage. Can only be used within 20 sec after you kill an enemy that yields experience or honor. Damage is based on your attack power. Learned at lvl 10.',\n    'New ability: Stance Mastery: You retain up to 10 rage points when you change stances. Learned at lvl 20.',\n    'Thunder Clap can now be used in defensive stance.',\n    'Slam can now be cast while moving and ignores pushback caused by damage.',\n    'Increased the time required for your rage to decay while out of combat 30%.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],["1120","1121"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],["1122","1123"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],["1124","1125"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1126"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1127"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],["1128","1129"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],["1130","1131"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1132"],"export default {\n  title: 'Druid',\n  content: [\n    'New ability: Lacerate: Lacerates the enemy target, dealing bleed damage over 15 sec and causing a high amount of threat.  Damage increased by attack power.  This effect stacks up to 5 times on the same target. Costs 15 rage and requires Bear Form or Dire Bear Form. Learned at level 44.',\n    'Tiger’s Fury reworked: now returns 40 energy and increases the damage of your next ability while in cat form by 25%. 1 minute cooldown.',\n    'Faerie Fire no longer costs mana, now has a 6 second cooldown and can be used in all forms.',\n    'Shred energy cost reduced to 45.',\n    'Frenzied Regeneration is now percentage based. Only one rank available.',\n    'Barkskin now reduces all damage taken by 25%, no longer reduces cast time and attack speed, and can be cast while frozen, incapacitated or feared. Cooldown is increased to 2 min.',\n    'Swipe now scales with attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],["1133","1134"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],["1135","1136"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1137"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1138"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],["1139","1140"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1141"],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1142"],"export default {\n  title: 'Mage',\n  content: [\n    'New ability: Arcane Blast: Blasts the target with energy, dealing Arcane damage. Each time you cast Arcane Blast, the casting time is reduced while mana cost is increased. Effect stacks up to 3 times and lasts 8 sec. Learned at lvl 24.',\n    'New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits. Gained after completing a new level 60 quest.',\n    'Cold Snap is now a baseline ability and learned at level 20.',\n    'Amplify magic reworked: Now increases spell damage done and spell damage taken by 2%. Only one Amplify Magic can be active per mage. Lasts 30 min.',\n    'Dampen Magic reworked: Now reduces spell damage done and spell damage taken by 2%. Only one Dampen Magic can be active per mage. Lasts 30 min.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1143"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1144"],"export default {\n  title: 'Rogue',\n  content: [\n    \"A new Evasion rank has been added that also increases the rogue's chance to dodge ranged attacks by 25%. Learned at lvl 50.\",\n    'Damaging poisons now scale with attack power and spell damage.',\n    'Expose Armor now stacks with Sunder Armor.',\n    'Increased the value of Pick Pocketed items from rare enemies.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1145"],"export default {\n  title: 'Itemization',\n  note: '',\n  content: [\n    'Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.',\n    'Existing class sets have been reworked to better fit their class and spec.',\n    'Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.',\n    'Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.',\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1146"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n",["1147","1148"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],["1149","1150"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1151"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1152"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1153"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Wyvern Venom',\n    'spell_nature_nullifypoison',\n    ['When activated, your next succesful melee or ranged attack causes the target to fall asleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the venom causes 500 damage over 12 sec.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '115 Mana',\n    null,\n    'Instant',\n    '2 min cooldown',\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["1154"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Invigoration',\n    'ability_hunter_invigeration',\n    ['When your pet scores a critical hit with a special ability, you instantly regenerate ', '% of your maximum mana. 10 sec cooldown.'],\n    2,\n    [[5, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent('Frenzy', 'inv_misc_monsterclaw_03', ['Gives your pet a ', '% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.'], 5, [[20, 40, 60, 80, 100]], [{ x: 3, y: 2 }]),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1155"],"export default {\n  title: 'Hunter',\n  content: [\n    'New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing your ranged and melee auto attacks to regenerate mana but reducing your total damage done by 10%.  In addition, you gain 10% of maximum mana every 3 sec.  Mana gained is based on the speed of your weapon. Only one Aspect can be active at a time. Learned at lvl 40.',\n    'New ability: Steady Shot: A steady shot that causes 100% ranged weapon damage. Learned at lvl 50.',\n    'Mongoose Bite now also activates after the hunter lands a melee critical strike.',\n    'Scorpid Sting reworked: Stings the target, reducing chance to hit with melee and ranged attacks by 3% for 20 sec. Only one Sting per Hunter can be active on any one target.',\n    'Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.',\n    'Aspect of the Beast now also greatly reduces the range at which hostile beasts will attack you and your pet.',\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s attack power.\",\n    'Stable slots increased to 5.',\n    'Traps can be set while in combat, but require a 2 second arming time.',\n    'Freezing Trap will now cancel combat when cast.',\n    'Auto shot will be automatically enabled if the Hunter steps out of melee range while in combat with target.',\n    '1 Agility will now grant 1 ranged and melee attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1156"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Serpent Sting', 'ability_hunter_quickshot', ['Increases the damage done by your Serpent Sting by ', '%.'], 3, [[10, 20, 30]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Improvied Scorpid Sting', 'ability_hunter_criticalshot', ['Increases the effect of your Scorpid Sting by ', '%.'], 2, [[1, 2]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1157"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Scatter Shot',\n    'ability_golemstormbolt',\n    ['A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.'],\n    1,\n    [[]],\n    null,\n    null,\n    '8% of base mana',\n    '15 yd range',\n    '30 sec cooldown'\n  ),\n  new Talent('Barrage', 'ability_upgrademoonglaive', ['Increases the damage done by your Multi-Shot and Volley spells by ', '%.'], 3, [[5, 10, 15]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent('Improved Steady Shot', 'ability_hunter_steadyshot', ['Gives your Steady Shot hits a ', '% chance to increase the damage of your next Aimed Shot or Arcane Shot by 30%.'], 3, [[5, 10, 15]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1158"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1159"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Readiness',\n    'ability_hunter_misdirection',\n    ['Threat caused by your next 3 attacks is redirected to the target raid member. Caster and target can only be affected by one Misdirection spell at a time.  Effect lasts 30 sec.'],\n    1,\n    [[]],\n    null,\n    null,\n    '9% of base mana',\n    '100 yd range',\n    'Instant',\n    '2 min cooldown',\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent('Killer Instinct', 'spell_holy_blessingofstamina', ['Increases your critical strike chance with all attacks by ', '%.'], 3, [[1, 2, 3]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent(\n    'Counterattack',\n    'ability_warrior_challange',\n    [\"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\"],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    '45 Mana',\n    'Melee range',\n    'Instant',\n    '5 sec cooldown'\n  ),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1160"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1161"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Trap Mastery',\n    'spell_nature_timestop',\n    ['Increases the duration of your Freezing and Frost traps by ', '% and the damage of your Explosive and Immolations traps by ', '%. In addition, reduces the chance your traps are resisted by ', '% and reduces the time to arm traps by ', ' sec.'],\n    2,\n    [\n      [15, 30],\n      [15, 30],\n      [5, 10],\n      [0.5, 1],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Survivalist', 'spell_shadow_twilight', ['Increases total health by ', '%.'], 5, [[2, 4, 6, 8, 10]]),\n  new Talent('Deterrence', 'ability_whirlwind', ['When activaed, increases dodge and parry chance by 25% for 10 sec.'], 1, [[]], [{ x: null, y: null }], [{ x: 4, y: 2 }], null, null, 'Instant', '5 min cooldown', ['D2']),\n  new Talent(\n    'Diligence',\n    'spell_shadow_summonimp',\n    ['When you deal Arcane, Fire or Nature damage with one of you abilities, you have a ', '% chance to cause your next Aimed Shot, Arcane Shot or Raptor Strike to trigger no cooldown.'],\n    2,\n    [[3, 6]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isChanged: false,\n      isMoved: false,\n      isNew: true,\n    }\n  ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1162"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Arcane Shot', 'ability_impalingbolt', ['Your Auto Shot hits reduce the cooldown of your Arcane Shot by ', ' sec.'], 2, [[0.25, 0.5]], null, [{ x: 2, y: 1 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Mortal Shots', 'ability_piercedamage', ['Increases your ranged critical strike damage bonus by ', '%.'], 5, [[6, 12, 18, 24, 39]], [{ x: 0, y: 2 }], null, null, null, null, null, null, { isNew: false, isChanged: false, isMoved: true }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1163"],"import React, { useState } from 'react'\nimport { useHistory, useLocation, useParams } from 'react-router-dom'\n\nimport SelectWrapper from './talent-calculator-select'\nimport TalentCalculatorMain from './talent-calculator-main/'\nimport styles from './index.module.css'\nimport ChangedSelect from './changed-select'\nimport { PlayerClassParam, URLParams } from '../../types'\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>()\n  const history = useHistory()\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`)\n  }\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true)\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true)\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true)\n\n  const toggleIsNew = () => setIsNew(!displayIsNew)\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged)\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved)\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  }\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  }\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect toggleChangedObj={toggleChangedObj} displayChanged={displayChanged} />\n      <TalentCalculatorMain displayChanged={displayChanged} selectedClass={playerClass} />\n    </div>\n  )\n}\n\nexport default TalentCalculator\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1164"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier1.ts",["1165"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Aspect of the Hawk', 'spell_nature_ravenform', ['While Aspect of the Hawk is active, all normal ranged attacks have a ', '% chance to increase your ranged attack speed by 30% for 12 sec.'], 5, [[1, 2, 3, 4, 5]]),\n  new Talent(\n    'Improved Aspect of the Monkey',\n    'ability_hunter_aspectofthemonkey',\n    ['While Aspect of the Money is active, all normal melee attacks have a ', '% chance to increase your critical strike chance with melee attacks by 10% for 8 sec.'],\n    5,\n    [[2, 4, 6, 8, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: true,\n    }\n  ),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/Classes.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier2.ts",["1166"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Entrapment',\n    'spell_nature_stranglevines',\n    ['Gives your Immolation Trap, Frost trap and Explosive Trap a ', '% chance to entrap the target, preventing them from moving for 5 sec.'],\n    3,\n    [[8, 16, 25]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Savage Strikes', 'ability_racial_bloodrage', ['Increases the critical strike chance of Raptor Strike and Mongoose Bite by ', '%.'], 2, [[10, 20]]),\n  new Talent('Improved Wing Clip', 'ability_rogue_trip', ['Gives your Wing Clip a ', '% to immobilize the target for 5 sec.'], 3, [[7, 14, 20]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Melee Weapon Specialization', 'inv_sword_05', ['Increases the damage you deal with melee attacks and abilities by ', '%.'], 3, [[3, 6, 9]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/undead.tsx",["1167"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier4.ts",["1168"],"import { Talent } from '../../Classes'\nexport default [\n  null,\n  new Talent('Caretaker', 'ability_hunter_mendpet', ['Gives your Mend Pet spell a ', '% chance to remove 1 poison, disease, curse of magic effect from your pet each tick.'], 2, [[15, 30]]),\n  new Talent('Ferocity', 'inv_misc_monsterclaw_04', ['Increases the critical strike chance of your pets by ', '%.'], 5, [[3, 6, 9, 12, 15]], [{ x: null, y: null }], [{ x: 5, y: 2 }], null, null, null, null, ['D2']),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier1.ts",[],["1169","1170"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier3.ts",["1171"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/reportWebVitals.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/human.tsx",["1172"],"export default {\n  title: 'Human',\n  content: ['New ability: Kirin Tor Legacy: Mana gained from all sources increased by 3%.', 'Mace Specialization removed.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/server-balance.ts",["1173"],"export default {\n  title: 'Server Balance',\n  content: [\n    'On servers where one faction is underrepresented, players of that faction gain bonus experience and reputation in proportion to this underrepresentation. This should encourage players to choose servers and factions with population issues.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talen