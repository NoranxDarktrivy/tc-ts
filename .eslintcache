lent('Lethal Shots', 'ability_searingarrow', ['Increases your critical strike chance with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]], [{ x: null, y: null }], [{ x: 1, y: 2 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: false,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/dwarf.tsx",["1178"],"export default {\n  title: 'Dwarf',\n  content: ['New ability: Mace Specialization: Increases your skill with maces by 5.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier5.ts",["1179"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Ferocious Inspiration',\n    'ability_hunter_ferociousinspiration',\n    ['When your pet scores a critical hit, all party members have their damage increased by ', \"% and all party members' pets and summons have their damage increased by \", '% for 10 sec.'],\n    3,\n    [\n      [1, 2, 3],\n      [3, 6, 9],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    'Intimidation',\n    'ability_devour',\n    ['Command your pet to intimidate the target on the next succesful melee attack, causing a high amount of threat and stunning the target for 3 sec.'],\n    1,\n    [[]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    '8% of base mana',\n    '100 yd range',\n    'Instant',\n    '1 min cooldown',\n    ['D2']\n  ),\n  null,\n  new Talent('Bestial Discipline', 'spell_nature_abolishmagic', ['Increases the Focus generation of your pets by ', '%.'], 2, [[10, 20]]),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/tooltip.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/paragraph.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/grid/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier7.ts",["1180"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-main/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/single-item.tsx",["1181"],"import React from 'react'\n\nimport { Item } from '../../data/example-items/Classes'\nimport { getClassColor } from '../../lib/ui-utils'\nimport { PlayerClassParam, Stats } from '../../types'\nimport styles from './index.module.css'\n\nconst SingleItemIcon: React.FC<{ img: string }> = ({ img }) => {\n  return (\n    <div className={styles.singleItemIconWrapper}>\n      <div className={styles.singleItemHighlight} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border-large.png\")` }} />\n      <div className={styles.singleItemIcon} style={{ background: `url(\"https://wow.zamimg.com/images/wow/icons/large/${img}.jpg\") 0 0 no-repeat` }} />\n      <div />\n    </div>\n  )\n}\n\nconst ItemName: React.FC<{ name: string; quality: string }> = ({ name, quality }) => {\n  const color = quality === 'epic' ? '#a335ee' : '#0070dd'\n  return (\n    <div className={styles.itemName} style={{ color }}>\n      {name}\n    </div>\n  )\n}\n\nconst ItemSlot: React.FC<{ slot: string; itemType: string | null | undefined }> = ({ slot, itemType }) => {\n  return (\n    <div className={styles.singleItemFlex}>\n      <div>{slot}</div>\n      <div>{itemType}</div>\n    </div>\n  )\n}\n\nconst ItemDmg: React.FC<{ damage: string | null | undefined; speed: string | null; dps: string | null }> = ({ damage, speed, dps }) => {\n  return (\n    <>\n      <div className={styles.singleItemFlex}>\n        <div>{speed}</div>\n        <div>{damage}</div>\n      </div>\n      <div className={styles.singleItemFlex}>{dps}</div>\n    </>\n  )\n}\n\nconst SingleStat: React.FC<{ stat: string; value: number }> = ({ stat, value }) => {\n  const sign = value < 0 ? '-' : '+'\n  const capitalKey = stat?.charAt(0).toUpperCase() + stat?.slice(1)\n\n  return (\n    <div className={styles.singleItemFlex}>\n      {sign}\n      {value} {capitalKey}\n    </div>\n  )\n}\n\nconst ItemStats: React.FC<{ stats: Stats }> = ({ stats }) => {\n  return (\n    <>\n      {Object.entries(stats).map(([stat, value], index) => {\n        if (!!value) return <SingleStat key={index} stat={stat} value={value} />\n      })}\n    </>\n  )\n}\n\nconst SingleItem: React.FC<Item> = ({ name, img, quality, slot, itemType, damage, speed, dps, stats, description, playerClass, levelRequired }) => {\n  const hasDmg = damage && speed && dps\n\n  return (\n    <div className={styles.singleItemWrapper}>\n      <SingleItemIcon img={img} />\n      <div className={styles.singleItemDescription} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/background/tooltip.png\")` }}>\n        <ItemName name={name} quality={quality} />\n        <ItemSlot slot={slot} itemType={itemType} />\n        {hasDmg && <ItemDmg damage={damage} speed={speed} dps={dps} />}\n        {stats && <ItemStats stats={stats} />}\n        {playerClass && (\n          <div className={styles.singleItemPlayerClass}>\n            Classes: <span style={{ color: getClassColor(playerClass.toLowerCase() as PlayerClassParam) }}>{playerClass}</span>\n          </div>\n        )}\n        <div className={styles.itemDescription}>{description && description.map((line, i) => <div key={i}>{line}</div>)}</div>\n        {levelRequired && <div className={styles.singleItemPlayerClass}>Requires level {levelRequired}</div>}\n      </div>\n    </div>\n  )\n}\n\nexport default SingleItem\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/index.tsx",["1182"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/night-elf.tsx",["1183"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/pa