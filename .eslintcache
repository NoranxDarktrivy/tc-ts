,"usedDeprecatedRules":"571"},{"filePath":"1137","messages":"1138","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1139","messages":"1140","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1141","messages":"1142","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1143","messages":"1144","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1145","messages":"1146","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1147","usedDeprecatedRules":"571"},{"filePath":"1148","messages":"1149","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1150","messages":"1151","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1152","usedDeprecatedRules":"571"},{"filePath":"1153","messages":"1154","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1155","usedDeprecatedRules":"571"},{"filePath":"1156","messages":"1157","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1158","usedDeprecatedRules":"571"},{"filePath":"1159","messages":"1160","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1161","usedDeprecatedRules":"571"},{"filePath":"1162","messages":"1163","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1164","messages":"1165","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1166","messages":"1167","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1168","messages":"1169","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1170","messages":"1171","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1172","messages":"1173","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1174","messages":"1175","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1176","messages":"1177","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1178","messages":"1179","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1180","messages":"1181","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1182","messages":"1183","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1184","messages":"1185","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},{"filePath":"1186","messages":"1187","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"571"},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1188"],"import general from './general'\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from './class-changes'\nimport factions from './factions'\nimport professions from './professions'\nimport itemization from './itemization'\nimport raceChanges from './race-changes'\n// import phases from './phases'\n\nexport default {\n  title: 'Patch notes',\n  sections: [general, classChanges, raceChanges, factions, itemization, professions],\n}\n",["1189","1190"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1191"],"import world from './general/world'\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from './general/server-balance'\nimport worldBuffs from './general/world-buffs'\nimport miscellaneous from './general/miscellaneous'\n\nexport default {\n  title: 'General',\n  note: 'The main goal of these proposed changes is to add diversity to World of Warcraft Classic, without trying to reinvent the game that we know and love. All QoL changes that are found in modern classic HC, as well as the new honor system are included.',\n  content: [world, serverBalance, worldBuffs, miscellaneous],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1192"],"export default {\n  title: 'Miscellaneous',\n  content: [\n    'Hit chance now applies to both to both spells and physical attacks unless otherwise specified.',\n    'Crit chance now applies to both to both spells and physical attacks unless otherwise specified.',\n    'Hit and spell hit are now one stat. Crit and spell crit are now one stat.',\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    'Quest log size increased to 30.',\n    'New class quests have been added.',\n    'Normal, elite and boss target dummies have been added to all major cities. Attacking these dummies does not increase weapon skill.',\n    'All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.',\n    \"New titles have been added: [City] Ambassador [Name] for exalted city reputation; [Name], The Explorer for uncovering all of Azeroth; [Rank] [Profession] [Name]; [Name] the Exalted for exalted reputation at all of your faction's capital cities.\",\n    'A disenchant option has been added to the need/greed UI.',\n    'World bosses now spawn more frequently and have improved loot tables.',\n    'The character pane now contains additional information like hit and crit.',\n    'Mail between characters on the same account is now instant.',\n    'The Troll weapon trainer now trains daggers.',\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n    'Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.',\n    'Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1193"],"export default {\n  title: \"Warlock\",\n  content: [\n    \"New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone. Learned after completing a new level 60 quest.\",\n    \"New ability: Soulshatter: Reduces threat by 50% for all enemies within 40 yards. Reagents: Soul Shard. 5 min cooldown. Learned at lvl 60\",\n    \"New ability: Incinerate: Deals Fire damage to your target and additional Fire damage if the target is affected by an Immolate spell. Learned at lvl 54.\",\n    \"Fel Domination is now a baseline ability and reduces the casting time and mana cost of your next summon spell by 100%.\",\n    \"Firestone is now a consumable item and significantly increases the Warlock's fire damage for 30 sec. 10 min cooldown. No longer grants attacks a chance to deal fire damage.\",\n    \"Spellstone is now a consumable item.\",\n    \"Hellfire now deals increased damage. The Warlock now only takes 50% of the damage caused by Hellfire.\",\n    \"Life Tap now scales with spirit.\",\n    \"Increased the health gained from Demon Armor.\",\n    \"Curse of Weakness now reduces the target's damage done by 5%. Only one rank available.\",\n    \"Warlocks can now summon party and raid members from within a dungeon or raid.\",\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    \"Soul Shards now stack up to 20 per bag slot.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1194"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1195"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1196"],"export default {\n  title: 'Warrior',\n  content: [\n    'New ability: Victory Rush: Instantly attack the target causing damage. Can only be used within 20 sec after you kill an enemy that yields experience or honor. Damage is based on your attack power. Learned at lvl 10.',\n    'New ability: Stance Mastery: You retain up to 10 rage points when you change stances. Learned at lvl 20.',\n    'Thunder Clap can now be used in defensive stance.',\n    'Slam can now be cast while moving and ignores pushback caused by damage.',\n    'Increased the time required for your rage to decay while out of combat 30%.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1197"],"export default {\n  title: \"Priest\",\n  content: [\n    \"Holy Nova is now a baseline ability and learned at level 20.\",\n    \"Increased the damage over time of Holy Fire.\",\n    \"Damage absorbed by your Power Word: Shield now increases with spell healing.\",\n    \"Fear Ward is now available to all races. Cooldown increased to 3 minutes, last 3 minutes. Fear Ward is now a discipline spell.\",\n    \"Feedback (Human) reduced mana cost and increased effect.\",\n    \"Chastise (Dwarf): new spell: Deals Holy damage and immoblizes the target, causing low theat. 20 yd range, 30 sec cooldown.\",\n    \"Elune’s Grace (Night Elf) now reduces the chance you are hit by melee or ranged attacks by 25% for 15 sec.\",\n    \"Starshards (Night Elf) now deals increased damage and lasts 4 sec. 1 min cooldown.\",\n    \"Shadowguard (Troll) orbs now look like shadow orbs instead of lightning.\",\n    \"Reduced the mana cost of Power Word: Fortitude, Prayer of Fortitude.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1198"],"export default {\n  title: 'Tauren',\n  content: ['New ability: Brawn: Increases critical strike damage and healing by 5%.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1199"],"export default {\n  title: \"Druid\",\n  content: [\n    \"New ability: Lacerate: Lacerates the enemy target, dealing bleed damage over 15 sec and causing a high amount of threat.  Damage increased by attack power.  This effect stacks up to 5 times on the same target. Costs 15 rage and requires Bear Form or Dire Bear Form. Learned at level 44.\",\n    \"Tiger’s Fury reworked: now returns 40 energy and increases the damage of your next ability while in cat form by 25%. 1 minute cooldown.\",\n    \"Faerie Fire no longer costs mana, now has a 6 second cooldown and can be used in all forms.\",\n    \"Frenzied Regeneration is now percentage based. Only one rank available.\",\n    \"Barkskin now reduces all damage taken by 25%, no longer reduces cast time and attack speed, and can be cast while frozen, incapacitated or feared. Cooldown is increased to 2 min.\",\n    \"Swipe now scales with attack power.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1200"],"export default {\n  title: 'Paladin',\n  content: [\n    'New ability: Hand of Reckoning: Taunts the target to attack you. 10 sec cooldown. Learned at lvl 16.',\n    'Consecration is now a baseline ability. Learned at lvl 20.',\n    'Judgement no longer costs mana.',\n    'Exorcism and Holy Wrath can now be cast against any target, but always critical hit against Undead and Demon targets.',\n    'Seal of the Crusader reworked: Successful attacks increase your attack speed by 4%. Stacks up to 10 times and lasts 12 sec. Judgement effect remains the same.',\n    'Seal of Justice effect now stuns up to two nearby enemies.',\n    'Judgement of Justice now also caps the target’s movement speed at 100%.',\n    'Blessing of Might now also increases ranged attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1201"],"export default {\n  title: \"Shaman\",\n  content: [\n    \"New ability: Totemic Recall: Removes all your totems and returns mana equal to 25% of their cost. Learned at lvl 4.\",\n    \"Increased the slow effect of Frostbrand Weapon to 50%.\",\n    \"Increased the radius of totems that affect friendly targets to 30 yards.\",\n    \"Sentry Totem now has stealth.\",\n    \"Stoneskin Totem now also reduces damage taken from ranged attacks.\",\n    \"Windwall Totem has been removed.\",\n    \"Stoneclaw Totem now has health equal to 20% of the Shaman’s health and has a 50% chance to stun enemies that attack it.\",\n    \"Shamans now retain their weapon skills when they unlearn Two-Handed Axes and Two-Handed Maces by changing talents.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1202"],"import { Item } from './Classes'\n\nexport default [\n  new Item('Libram of Wrath', 'inv_misc_book_07', 'epic', 'Relic', 'Libram', null, null, null, null, ['Allows your Hammer of Wrath to be cast on targets with any amount of health, but reduces the damage by 95%.']),\n  new Item('Totem of Tempest', 'inv_jewelry_amulet_06', 'epic', 'Relic', 'Totem', null, null, null, null, ['Reduces the threat of additional attacks from your Windury Weapon by 75%.']),\n  new Item('Band of Guidance', 'inv_jewelry_ring_43', 'epic', 'Finger', null, null, null, null, null, ['Equip: Increases your chance to hit by 2%.', 'Equip: Increases your chance to hit with spells by 2%.']),\n  new Item('Daybreak', 'inv_hammer_04', 'epic', 'Two-hand', 'Mace', 'Speed 3.00', '131 - 255 Damage', '(59.33 damage per second)', null, ['Chance on hit: physical damage taken by target increased by 10% for 8 sec.']),\n  new Item('Idol of the World Tree', 'inv_qirajidol_night', 'rare', 'Relic', 'Idol', null, null, null, null, ['Increases the duration of your Rejuvenation and Regrowth spells by 4 sec.']),\n  new Item('Jewel of Synergy', 'inv_jewelry_ring_64', 'epic', 'Trinket', null, null, null, null, null, ['Increases your spell damage by 10% for 8 sec after dealing damage from three different magic schools within 3 sec.']),\n  new Item('Book of Command', 'warlock_grimoireofcommand', 'epic', 'Trinket', null, null, null, null, null, ['Use: Increases the damage and critical strike chance of your active pets and summons by 25% for 15 sec. (3 min cooldown)']),\n  // new Item('Totem of Tidal Orbs', 'inv_qirajidol_life', 'epic', 'Relic', 'Totem', null, null, null, null, ['Damage from your Lightning Shield returns mana equal to 60% of the damage dealt.']),\n  // new Item(\n  //   'Breastplate of Victory',\n  //   'inv_chest_plate07',\n  //   'rare',\n  //   'Chest',\n  //   'Mail',\n  //   null,\n  //   null,\n  //   null,\n  //   { armor: 207, stamina: 0, strength: 0, intellect: 0, spirit: 0, agility: 0 },\n  //   ['Gain 10 rage and 10% health after killing an opponent that yields experience or honor.'],\n  //   'Warrior',\n  //   27\n  // ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1203"],"export default {\n  title: \"Mage\",\n  content: [\n    \"New ability: Arcane Blast: Blasts the target with energy, dealing Arcane damage. Each time you cast Arcane Blast, the casting time is reduced while mana cost is increased. Effect stacks up to 3 times and lasts 8 sec. Learned at lvl 24.\",\n    \"New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits. Gained after completing a new level 60 quest.\",\n    \"Ice Block is now a baseline ability and learned at level 30.\",\n    \"Amplify magic reworked: Now increases spell damage done and spell damage taken by 2%. Only one Amplify Magic can be active per mage. Lasts 30 min.\",\n    \"Dampen Magic reworked: Now reduces spell damage done and spell damage taken by 2%. Only one Dampen Magic can be active per mage. Lasts 30 min.\",\n    \"Reduced the mana cost of Arcane Intellect and Arcane Brilliance.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1204"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1205"],"export default {\n  title: \"Rogue\",\n  content: [\n    \"New ability: Redirect: Transfers any existing combo points to the current enemy target. 1 min cooldown. Learned at lvl 30.\",\n    \"Garrote now also silences the target for 3 seconds.\",\n    \"A new Evasion rank has been added that also increases the rogue's chance to dodge ranged attacks by 25%. Learned at lvl 50.\",\n    \"Expose Armor now stacks with Sunder Armor.\",\n    \"Increased the value of Pick Pocketed items from rare enemies.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1206"],"export default {\n  title: \"Itemization\",\n  note: \"\",\n  content: [\n    \"Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.\",\n    \"Existing class sets have been reworked to better fit their class and spec.\",\n    \"Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1207"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1208"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1209"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Hawk Eye\",\n    \"ability_townwatch\",\n    [\"Increases the range of your ranged weapons by \", \" yards.\"],\n    3,\n    [[2, 4, 6]]\n  ),\n  new Talent(\n    \"Untamed\",\n    \"spell_nature_dryaddispelmagic\",\n    [\n      \"Increases your Arcane, Fire and Nature damage by up to \",\n      \"% of your attack power.\",\n    ],\n    5,\n    [[10, 20, 30, 40, 50]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Deflection\",\n    \"ability_parry\",\n    [\"Increases your parry chance by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1210"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Wyvern Shot\",\n    \"spell_nature_nullifypoison\",\n    [\n      \"A shot that causes the target to fall asleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the venom causes 500 damage over 12 sec.\",\n    ],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    \"115 Mana\",\n    \"20 yd range\",\n    \"2 sec cast\",\n    \"1 min cooldown\",\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["1211"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Ferocious Inspiration\",\n    \"ability_hunter_ferociousinspiration\",\n    [\n      \"When your pet scores a critical hit, all party members have their damage and healing increased by \",\n      \"% and all party members' pets and summons have their damage increased by \",\n      \"% for 10 sec.\",\n    ],\n    2,\n    [\n      [1, 2, 3],\n      [3, 6, 9],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent(\n    \"Frenzy\",\n    \"inv_misc_monsterclaw_03\",\n    [\n      \"Gives your pet a \",\n      \"% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.\",\n    ],\n    5,\n    [[20, 40, 60, 80, 100]],\n    [{ x: 3, y: 2 }]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1212"],"export default {\n  title: \"Hunter\",\n  content: [\n    \"New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing your ranged and melee auto attacks to regenerate mana but reducing your total damage done by 10%.  In addition, you gain 10% of maximum mana every 3 sec.  Mana gained is based on the speed of your weapon. Only one Aspect can be active at a time. Learned at lvl 40.\",\n    \"New ability: Steady Shot: A steady shot that causes 100% ranged weapon damage. Learned at lvl 50.\",\n    \"Mongoose Bite now also activates after the hunter lands a melee critical strike.\",\n    \"Aspect of the Beast reworked: now also increases the melee attack power of the hunter and the hunter's pet by 10%. Learned at lvl 12.\",\n    \"Scorpid Sting reworked: Stings the target, reducing chance to hit with melee and ranged attacks by 3% for 20 sec. Only one Sting per Hunter can be active on any one target.\",\n    \"Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.\",\n    \"Aspect of the Beast now also greatly reduces the range at which hostile beasts will attack you and your pet.\",\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s attack power.\",\n    \"Stable slots increased to 5.\",\n    \"Traps can be set while in combat, but require a 2 second arming time.\",\n    \"Freezing Trap will now cancel combat when cast.\",\n    \"Auto shot will be automatically enabled if the Hunter steps out of melee range while in combat with target.\",\n    \"1 Agility will now grant 1 ranged and melee attack power.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1213"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Improved Serpent Sting\",\n    \"ability_hunter_quickshot\",\n    [\"Increases the damage done by your Serpent Sting by \", \"%.\"],\n    3,\n    [[10, 20, 30]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Bow Specialization\",\n    \"inv_weapon_bow_03\",\n    [\n      \"Gives you a \",\n      \"% chance to trigger an additional attack against the same target when using bows.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Crossbow Specialization\",\n    \"inv_weapon_crossbow_04\",\n    [\"Increases your attack speed with Crossbows by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Gun Specialization\",\n    \"inv_weapon_rifle_02\",\n    [\n      \"Increases your critical strike chance and critical strike damage with Guns by \",\n      \"%.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1214"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1215"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1216"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Hunting Party\",\n    \"ability_hunter_huntingparty\",\n    [\n      \"After dealing a melee or ranged critical strike, you and a random party member within 40 yards gain \",\n      \"% increased attack speed for 6 sec.\",\n    ],\n    2,\n    [[5, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Killer Instinct\",\n    \"spell_holy_blessingofstamina\",\n    [\"Increases your critical strike chance with all attacks by \", \"%.\"],\n    3,\n    [[1, 2, 3]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Counterattack\",\n    \"ability_warrior_challange\",\n    [\n      \"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\",\n    ],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    \"45 Mana\",\n    \"Melee range\",\n    \"Instant\",\n    \"5 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1217"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1218"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Trap Mastery\",\n    \"spell_nature_timestop\",\n    [\n      \"Increases the duration of your Freezing and Frost traps by \",\n      \"% and the damage of your Explosive and Immolations traps by \",\n      \"%. In addition, reduces the chance your traps are resisted by \",\n      \"% and reduces the time to arm traps by \",\n      \" sec.\",\n    ],\n    2,\n    [\n      [15, 30],\n      [15, 30],\n      [5, 10],\n      [0.5, 1],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Survivalist\",\n    \"spell_shadow_twilight\",\n    [\"Increases total health by \", \"%.\"],\n    5,\n    [[2, 4, 6, 8, 10]]\n  ),\n  new Talent(\n    \"Deterrence\",\n    \"ability_whirlwind\",\n    [\"When activaed, increases dodge and parry chance by 25% for 10 sec.\"],\n    1,\n    [[]],\n    [{ x: null, y: null }],\n    [{ x: 4, y: 2 }],\n    null,\n    null,\n    \"Instant\",\n    \"5 min cooldown\",\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Diligence\",\n    \"spell_shadow_summonimp\",\n    [\n      \"When you deal Arcane, Fire or Nature damage with one of you abilities, you have a \",\n      \"% chance reset the cooldown of you Aimed Shot, Arcane Shot and Raptor Strike.\",\n    ],\n    2,\n    [[3, 6]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isChanged: false,\n      isMoved: false,\n      isNew: true,\n    }\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1219"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Arcane Shot', 'ability_impalingbolt', ['Your Auto Shot hits reduce the cooldown of your Arcane Shot by ', ' sec.'], 2, [[0.25, 0.5]], null, [{ x: 2, y: 1 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Mortal Shots', 'ability_piercedamage', ['Increases your ranged critical strike damage bonus by ', '%.'], 5, [[6, 12, 18, 24, 39]], [{ x: 0, y: 2 }], null, null, null, null, null, null, { isNew: false, isChanged: false, isMoved: true }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1220"],"import React, { useState } from 'react'\nimport { useHistory, useLocation, useParams } from 'react-router-dom'\n\nimport SelectWrapper from './talent-calculator-select'\nimport TalentCalculatorMain from './talent-calculator-main/'\nimport styles from './index.module.css'\nimport ChangedSelect from './changed-select'\nimport { PlayerClassParam, URLParams } from '../../types'\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>()\n  const history = useHistory()\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`)\n  }\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true)\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true)\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true)\n\n  const toggleIsNew = () => setIsNew(!displayIsNew)\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged)\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved)\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  }\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  }\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect toggleChangedObj={toggleChangedObj} displayChanged={displayChanged} />\n      <TalentCalculatorMain displayChanged={displayChanged} selectedClass={playerClass} />\n    </div>\n  )\n}\n\nexport default TalentCalculator\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1221"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier1.ts",["1222"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/Classes.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier2.ts",["1223"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Entrapment',\n    'spell_nature_stranglevines',\n    ['Gives your Immolation Trap, Frost trap and Explosive Trap a ', '% chance to entrap the target, preventing them from moving for 5 sec.'],\n    3,\n    [[8, 16, 25]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Savage Strikes', 'ability_racial_bloodrage', ['Increases the critical strike chance of Raptor Strike and Mongoose Bite by ', '%.'], 2, [[10, 20]]),\n  new Talent('Improved Wing Clip', 'ability_rogue_trip', ['Gives your Wing Clip a ', '% to immobilize the target for 5 sec.'], 3, [[7, 14, 20]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Melee Weapon Specialization', 'inv_sword_05', ['Increases the damage you deal with melee attacks and abilities by ', '%.'], 3, [[3, 6, 9]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/undead.tsx",["1224"],"export default {\n  title: 'Undead',\n  content: ['New ability: Embrace of Undeath: Deal 10% additional damage to targets below 10% health.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier4.ts",["1225"],"import { Talent } from '../../Classes'\nexport default [\n  null,\n  new Talent('Caretaker', 'ability_hunter_mendpet', ['Gives your Mend Pet spell a ', '% chance to remove 1 poison, disease, curse of magic effect from your pet each tick.'], 2, [[15, 30]]),\n  new Talent('Ferocity', 'inv_misc_monsterclaw_04', ['Increases the critical strike chance of your pets by ', '%.'], 5, [[3, 6, 9, 12, 15]], [{ x: null, y: null }], [{ x: 5, y: 2 }], null, null, null, null, ['D2']),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier3.ts",["1226"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/reportWebVitals.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/human.tsx",["1227"],"export default {\n  title: \"Human\",\n  content: [\"Mace Specialization removed.\"],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/server-balance.ts",["1228"],"export default {\n  title: 'Server Balance',\n  content: [\n    'On servers where one faction is underrepresented, players of that faction gain bonus experience and reputation in proportion to this underrepresentation. This should encourage players to choose servers and factions with population issues.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier3.ts",["1229"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Pathfinding',\n    'ability_mount_jungletiger',\n    ['Increases the speed bonus of your Aspect of the Cheetah and Aspect of the Pack by ', '% and increases the outdoor movement speed of your pets by ', '%.'],\n    2,\n    [\n      [3, 6],\n      [15, 30],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: false, isChanged: true, isMoved: false }\n  ),\n  new Talent(\n    'Kill Command',\n    'ability_hunter_killcommand',\n    ['Give the command to kill, causing your pet to instantly attack for an additional 12 damage. Can only be used after the Hunter lands a critical strike on the target.'],\n    1,\n    [[]],\n    null,\n    null,\n    '27 Mana',\n    '45 yd range',\n    'Instant',\n    '5 sec cooldown',\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent('Unleashed Fury', 'ability_bullrush', ['Increases the damage done by your pets by ', '%.'], 5, [[4, 8, 12, 16, 20]]),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/App.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/nav-bar/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/troll.tsx",["1230"],"export default {\n  title: 'Troll',\n  content: [\n    'Bow Specialization removed.',\n    \"New ability: Da Voodoo Shuffle: Reduces the duration of all movement impairing effects by 15%.  Trolls be flippin' out mon!\",\n    'New ability: Dagger Specialization: increases your skill with daggers by 5.',\n    'Troll Regeneration now restores 1% health every 5 seconds.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier7.ts",["1231"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Bestial Wrath',\n    'ability_druid_ferociousbite',\n    ['Send your pet into a rage causing 50% additional damage for 18 sec. While enraged, the beast does not feel pity or remorse or fear and it cannot be stopped unless killed.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '12% of base mana',\n    '100 yd range',\n    'Instant',\n    '2 min cooldown'\n  ),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier1.ts",["1232"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\"Improved Hunter's Mark\", 'ability_hunter_snipershot', ['Causes ', \"% of your Hunter's Mark ability to apply to melee attack power as well.\"], 2, [[50, 100]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Improved Concussive Shot', 'spell_frost_stun', ['Gives your Concussive Shot a ', '% chance to stun the target for 3 sec.'], 5, [[4, 8, 12, 16, 20]]),\n  new Talent('Lethal Shots', 'ability_searingarrow', ['Increases your critical strike chance with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]], [{ x: null, y: null }], [{ x: 1, y: 2 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: false,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/dwarf.tsx",["1233"],"export default {\n  title: 'Dwarf',\n  content: ['New ability: Mace Specialization: Increases your skill with maces by 5.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier2.ts",["1234"],"import { Talent } from \"../../Classes\";\n\nconst tier2 = [\n  new Talent(\n    \"Earth's Grasp\",\n    \"spell_nature_stoneclawtotem\",\n    [\n      \"Increases the health of your Stoneclaw Totem by \",\n      \"% and the radius of your Earthbind Totem by \",\n      \"%.\",\n    ],\n    2,\n    [\n      [25, 50],\n      [20, 40],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Spiritual Warding\",\n    \"spell_nature_spiritarmor\",\n    [\n      \"Reduces the damage taken from Frost, Fire and Nature spells and effects by \",\n      \"%.\",\n    ],\n    3,\n    [[4, 7, 10]]\n  ),\n  new Talent(\n    \"Call of Flame\",\n    \"spell_fire_immolation\",\n    [\"Increases damage done by your Fire Totems by \", \"%.\"],\n    3,\n    [[5, 10, 15]]\n  ),\n  new Talent(\n    \"Focused Insight\",\n    \"spell_shaman_measuredinsight\",\n    [\n      \"After casting any Shock spell, your next heal's mana cost is reduced by \",\n      \"% of the cost of the Shock spell, and its healing effectiveness is increased by \",\n      \"%.\",\n    ],\n    3,\n    [\n      [25, 50, 75],\n      [10, 20, 30],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isChanged: false, isNew: true, isMoved: false }\n  ),\n  ,\n];\n\nexport default tier2;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier5.ts",["1235"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Intimidation\",\n    \"ability_devour\",\n    [\n      \"Command your pet to intimidate the target on the next succesful melee attack, causing a high amount of threat and stunning the target for 3 sec.\",\n    ],\n    1,\n    [[]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    \"8% of base mana\",\n    \"100 yd range\",\n    \"Instant\",\n    \"1 min cooldown\",\n    [\"D2\"]\n  ),\n  null,\n  new Talent(\n    \"Bestial Discipline\",\n    \"spell_nature_abolishmagic\",\n    [\"Increases the Focus generation of your pets by \", \"%.\"],\n    2,\n    [[10, 20]]\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/tooltip.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/paragraph.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/grid/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier7.ts",["1236"],"import { Talent } from '../../Classes'\n\nexport default [null, new Talent('Trueshot Aura', 'ability_trueshot', ['Increases the attack power of party members within 45 yards by 50. Lasts 30 min.'], 1, [[]], [{ x: 4, y: 1 }], null, '325 Mana', null, 'Instant'), null, null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-main/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/single-item.tsx",["1237"],"import React from 'react'\n\nimport { Item } from '../../data/example-items/Classes'\nimport { getClassColor } from '../../lib/ui-utils'\nimport { PlayerClassParam, Stats } from '../../types'\nimport styles from './index.module.css'\n\nconst SingleItemIcon: React.FC<{ img: string }> = ({ img }) => {\n  return (\n    <div className={styles.singleItemIconWrapper}>\n      <div className={styles.singleItemHighlight} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border-large.png\")` }} />\n      <div className={styles.singleItemIcon} style={{ background: `url(\"https://wow.zamimg.com/images/wow/icons/large/${img}.jpg\") 0 0 no-repeat` }} />\n      <div />\n    </div>\n  )\n}\n\nconst ItemName: React.FC<{ name: string; quality: string }> = ({ name, quality }) => {\n  const color = quality === 'epic' ? '#a335ee' : '#0070dd'\n  return (\n    <div className={styles.itemName} style={{ color }}>\n      {name}\n    </div>\n  )\n}\n\nconst ItemSlot: React.FC<{ slot: string; itemType: string | null | undefined }> = ({ slot, itemType }) => {\n  return (\n    <div className={styles.singleItemFlex}>\n      <div>{slot}</div>\n      <div>{itemType}</div>\n    </div>\n  )\n}\n\nconst ItemDmg: React.FC<{ damage: string | null | undefined; speed: string | null; dps: string | null }> = ({ damage, speed, dps }) => {\n  return (\n    <>\n      <div className={styles.singleItemFlex}>\n        <div>{speed}</div>\n        <div>{damage}</div>\n      </div>\n      <div className={styles.singleItemFlex}>{dps}</div>\n    </>\n  )\n}\n\nconst SingleStat: React.FC<{ stat: string; value: number }> = ({ stat, value }) => {\n  const sign = value < 0 ? '-' : '+'\n  const capitalKey = stat?.charAt(0).toUpperCase() + stat?.slice(1)\n\n  return (\n    <div className={styles.singleItemFlex}>\n      {sign}\n      {value} {capitalKey}\n    </div>\n  )\n}\n\nconst ItemStats: React.FC<{ stats: Stats }> = ({ stats }) => {\n  return (\n    <>\n      {Object.entries(stats).map(([stat, value], index) => {\n        if (!!value) return <SingleStat key={index} stat={stat} value={value} />\n      })}\n    </>\n  )\n}\n\nconst SingleItem: React.FC<Item> = ({ name, img, quality, slot, itemType, damage, speed, dps, stats, description, playerClass, levelRequired }) => {\n  const hasDmg = damage && speed && dps\n\n  return (\n    <div className={styles.singleItemWrapper}>\n      <SingleItemIcon img={img} />\n      <div className={styles.singleItemDescription} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/background/tooltip.png\")` }}>\n        <ItemName name={name} quality={quality} />\n        <ItemSlot slot={slot} itemType={itemType} />\n        {hasDmg && <ItemDmg damage={damage} speed={speed} dps={dps} />}\n        {stats && <ItemStats stats={stats} />}\n        {playerClass && (\n          <div className={styles.singleItemPlayerClass}>\n            Classes: <span style={{ color: getClassColor(playerClass.toLowerCase() as PlayerClassParam) }}>{playerClass}</span>\n          </div>\n        )}\n        <div className={styles.itemDescription}>{description && description.map((line, i) => <div key={i}>{line}</div>)}</div>\n        {levelRequired && <div className={styles.singleItemPlayerClass}>Requires level {levelRequired}</div>}\n      </div>\n    </div>\n  )\n}\n\nexport default SingleItem\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/index.tsx",["1238"],"import React, { useState } from 'react'\n\nimport { Talent } from '../../../data/talents/Classes'\nimport Tooltip from './tooltip'\nimport Arrow from './arrow'\nimport styles from './cell.module.css'\nimport ChangedBar from './changed-bar'\nimport { useParams } from 'react-router-dom'\nimport { URLParams } from '../../../types'\n\ninterface CellProps {\n  cellData: Talent\n  i: number\n  x: number\n  y: number\n  color: string | null\n  clickHandler: (i: number, x: number, y: number, e: React.MouseEvent<HTMLElement>) => void\n  displayChanged: {\n    displayIsNew: boolean\n    displayIsChanged: boolean\n    displayIsMoved: boolean\n  }\n}\n\nconst Cell: React.FC<CellProps> = ({ cellData, i, x, y, color, clickHandler, displayChanged }) => {\n  const { talentPoints } = useParams<URLParams>()\n  const [showTooltip, set_showTooltip] = useState<boolean>(false)\n  const { value, maxValue, icon, manaCost, range, castTime, cooldown, name, arrows, changed } = cellData\n\n  const borderColor = !!color ? `2px solid ${color}` : `2px solid black`\n  const cellFilter = !color ? 'grayscale(100%)' : 'none'\n\n  // yes: value\n\n  return (\n    <div\n      className={styles.cellWrapper}\n      onMouseEnter={() => {\n        set_showTooltip(true)\n      }}\n      onMouseLeave={() => {\n        set_showTooltip(false)\n      }}>\n      <ChangedBar displayChanged={displayChanged} changed={changed} />\n      <div className={styles.cellHighlight} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border.png\")` }} />\n      <div\n        style={{\n          background: `url(\"https://wow.zamimg.com/images/wow/icons/medium/${icon}.jpg\") 0 0 no-repeat`,\n          border: borderColor,\n          filter: cellFilter,\n        }}\n        className={styles.cellIconStyle}>\n        <button\n          className={styles.cellButtonStyle}\n          onClick={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}\n          onContextMenu={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}>\n          <div className={styles.cellPointsStyle} style={{ color: color ? 'white' : '#787878' }}>\n            {`${value}/${maxValue}`}\n          </div>\n        </button>\n      </div>\n      {showTooltip && <Tooltip value={cellData.value} description={cellData.description} maxValue={cellData.maxValue} valueIteration={cellData.valueIteration} manaCost={manaCost} range={range} castTime={castTime} cooldown={cooldown} name={name} />}\n      {arrows &&\n        arrows.map((arrow, i) => {\n          return <Arrow arrowData={arrow} color={color} key={i} />\n        })}\n    </div>\n  )\n}\n\nexport default Cell\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/night-elf.tsx",["1239"],"export default {\n  title: \"Night Elf\",\n  content: [\n    \"New ability: Elusiveness: Increases stealth level by 1 and movement speed while stealthed by 5%.\",\n    \"Shadowmeld no longer increases stealth level.\",\n    \"Quickness now also increase melee attack speed by 1%.\",\n    \"Added Bow Specialization: Increases your skill with bows by 5.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/orc.tsx",["1240"],"export default {\n  title: 'Orc',\n  content: ['Blood Fury: now also increases your spell damage and healing and ranged attack power.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/ui-utils.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/talents-url.tsx",["1241","1242"],"import { Talent } from '../data/talents/Classes'\nimport { ClassSpecType, ClassTalentType } from '../types'\n\nconst flattenSpec = (specData: ClassSpecType) => {\n  return specData.flatMap(row => row)\n}\n\nexport const flattenTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return talentData.flatMap(flattenSpec)\n}\n\nexport const getFlattenedTalentValues = (talentData: ClassTalentType | null) => {\n  const flattenedTalents = flattenTalents(talentData)\n  return flattenedTalents.map(talent => talent?.value).filter(talent => !isNaN(talent!))\n}\n\nconst getTruthyTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return flattenTalents(talentData).filter(talent => talent)\n}\n\nconst loopURLTalents = (flatTalents: (Talent | null)[], talentsFromUrl: string) => {\n  let stringIndex: number = 0\n\n  for (let i = 0; i < flatTalents.length; i++) {\n    if (!!flatTalents[i]) {\n      flatTalents[i]?.setValue(parseInt(talentsFromUrl[stringIndex]))\n      stringIndex++\n    }\n  }\n}\n\n// http://localhost:3000/tc-ts#/tc/druid/0140003000000000050023011000000000055003115010000\n\nexport const loopTalentsFromUrl = (talentData: ClassTalentType | null, talentPoints: string) => {\n  if (!talentData) return []\n\n  let stringIndex: number = 0\n\n  talentData.forEach(spec => {\n    spec.forEach(row => {\n      row.forEach(cell => {\n        if (!!cell) {\n          cell.setValue(parseInt(talentPoints[stringIndex]))\n          stringIndex++\n        }\n      })\n    })\n  })\n\n  return talentData\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-footer/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/professions/index.ts",["1243"],"export default {\n  title: 'Professions',\n  note: '',\n  content: [\n    'Players can now select their profession and rank as title. For example “Artisan Blacksmith [Name]”.',\n    'Many profession quests have been added.',\n    'Various new recipes have been added. Many crafting professions should generally offer stronger options for both endgame and leveling content.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/index.ts",["1244"],"import dwarf from './race-changes/dwarf'\nimport gnome from './race-changes/gnome'\nimport human from './race-changes/human'\nimport nightElf from './race-changes/night-elf'\nimport orc from './race-changes/orc'\nimport tauren from './race-changes/tauren'\nimport troll from './race-changes/troll'\nimport undead from './race-changes/undead'\n\nexport default {\n  title: 'Race changes',\n  note: 'Some race/class combinations are lacking in certain areas, or get outcompeted in certain roles. These changes aim to create a niche for each race/class combindation in both PvE and PvP, while still retaining their core fantasies.',\n  content: [human, dwarf, gnome, nightElf, orc, troll, tauren, undead],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter-pets.ts",["1245"],"export default {\n  title: 'Hunter pets',\n  content: [\n    'Bears can now also learn Swipe, which deals mediocre damage in a frontal cone.',\n    'Crabs can now also learn Pincer, reducing the target’s armor while increasing their own armor.',\n    'Crocolisks can now learn Crushing Jaw, which has a 100% crit chance and 12 sec cooldown.',\n    'Hyenas and Raptors can now also learn Gore, a damaging ability that has a 50% chance to deal dubble damage.',\n    'Spiders can now also learn Spider Poison, which has the same effect as Scorpid Poison.',\n    'Tallstriders can now also learn Screech.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/index.tsx",["1246"],"import druid from './classes/druid'\nimport hunter from './classes/hunter'\nimport hunterPets from './classes/hunter-pets'\nimport mage from './classes/mage'\nimport paladin from './classes/paladin'\nimport priest from './classes/priest'\nimport rogue from './classes/rogue'\nimport shaman from './classes/shaman'\nimport warlock from './classes/warlock'\n// import warlockDemons from './classes/warlock-demons'\nimport warrior from './classes/warrior'\n\nexport default {\n  title: 'Class changes',\n  note: 'The aim of these class changes is to add diversity and improve specs that are lacking in certain areas of the game. Additionaly, some underused or awkward abilities are targeted to make them more interesting.',\n  content: [druid, hunter, hunterPets, mage, paladin, priest, rogue, shaman, warlock, warrior],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier1.ts",[],{"ruleId":"1247","severity":1,"message":"1248","line":11,"column":1,"nodeType":"1249","endLine":14,"endColumn":2},{"ruleId":"1250","replacedBy":"1251"},{"ruleId":"1252","replacedBy":"1253"},{"ruleId":"1247","severity":1,"message":"1248","line":8,"column":1,"nodeType":"1249","end