:"1078","messages":"1079","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1080","messages":"1081","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1082","messages":"1083","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1084"},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1085"],"import general from './general'\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from './class-changes'\nimport factions from './factions'\nimport professions from './professions'\nimport itemization from './itemization'\nimport raceChanges from './race-changes'\n// import phases from './phases'\n\nexport default {\n  title: 'Patch notes',\n  sections: [general, classChanges, raceChanges, factions, itemization, professions],\n}\n",["1086","1087"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1088"],"import world from './general/world'\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from './general/server-balance'\nimport worldBuffs from './general/world-buffs'\nimport miscellaneous from './general/miscellaneous'\n\nexport default {\n  title: 'General',\n  note: 'The main goal of these proposed changes is to add diversity to World of Warcraft Classic, without trying to reinvent the game that we know and love. All QoL changes that are found in modern classic HC, as well as the new honor system are included.',\n  content: [world, serverBalance, worldBuffs, miscellaneous],\n}\n",["1089","1090"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1091"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1092"],"export default {\n  title: 'Warlock',\n  content: [\n    'New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone. Learned after completing a new level 60 quest.',\n    'New ability: Soulshatter: Reduces threat on the target by 100%. Reagents: Soul Shard. 2 min cooldown. Learned at lvl 60',\n    'New ability: Incinerate: Deals Fire damage to your target and additional Fire damage if the target is affected by an Immolate spell. Learned at lvl 54.',\n    'Firestone bonus fire spell damage increased. No longer grants attacks a chance to deal fire damage.',\n    'Spellstone now increases your spell damage by a small amount and increases hit chance by 2%.',\n    'Hellfire now deals increased damage. The Warlock now only takes 50% of the damage caused by Hellfire.',\n    'Increased the health gained from Demon Armor.',\n    \"Curse of Weakness now reduces the target's damage done by 5%. Only one rank available.\",\n    'Warlocks can now summon party and raid members from within a dungeon or raid.',\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    'Soul Shards now stack up to 20 per bag slot.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1093"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1094","1095"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1096"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1097"],"export default {\n  title: 'Warrior',\n  content: [\n    'New ability: Victory Rush: Instantly attack the target causing damage. Can only be used within 20 sec after you kill an enemy that yields experience or honor. Damage is based on your attack power. Learned at lvl 10.',\n    'New ability: Stance Mastery: You retain up to 10 rage points when you change stances. Learned at lvl 20.',\n    'Thunder Clap can now be used in defensive stance.',\n    'Slam can now be cast while moving and ignores pushback caused by damage.',\n    'Increased the time required for your rage to decay while out of combat 30%.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],["1098","1099"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],["1100","1101"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],["1102","1103"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1104"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1105"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],["1106","1107"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],["1108","1109"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1110"],"export default {\n  title: 'Druid',\n  content: [\n    'New ability: Lacerate: Lacerates the enemy target, dealing bleed damage over 15 sec and causing a high amount of threat.  Damage increased by attack power.  This effect stacks up to 5 times on the same target. Costs 15 rage and requires Bear Form or Dire Bear Form. Learned at level 44.',\n    'Tiger’s Fury reworked: now returns 40 energy and increases the damage of your next ability while in cat form by 25%. 1 minute cooldown.',\n    'Faerie Fire no longer costs mana, now has a 6 second cooldown and can be used in all forms.',\n    'Shred energy cost reduced to 45.',\n    'Frenzied Regeneration is now percentage based. Only one rank available.',\n    'Barkskin now reduces all damage taken by 25%, no longer reduces cast time and attack speed, and can be cast while frozen, incapacitated or feared. Cooldown is increased to 2 min.',\n    'Swipe now scales with attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],["1111","1112"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],["1113","1114"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1115"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1116"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],["1117","1118"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1119"],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1120"],"export default {\n  title: 'Mage',\n  content: [\n    'New ability: Arcane Blast: Blasts the target with energy, dealing Arcane damage. Each time you cast Arcane Blast, the casting time is reduced while mana cost is increased. Effect stacks up to 3 times and lasts 8 sec. Learned at lvl 24.',\n    'New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits. Gained after completing a new level 60 quest.',\n    'Cold Snap is now a baseline ability and learned at level 20.',\n    'Amplify magic reworked: Now increases spell damage done and spell damage taken by 2%. Only one Amplify Magic can be active per mage. Lasts 30 min.',\n    'Dampen Magic reworked: Now reduces spell damage done and spell damage taken by 2%. Only one Dampen Magic can be active per mage. Lasts 30 min.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1121"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n",["1122","1123"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1124"],"export default {\n  title: 'Rogue',\n  content: [\n    \"A new Evasion rank has been added that also increases the rogue's chance to dodge ranged attacks by 25%. Learned at lvl 50.\",\n    'Damaging poisons now scale with attack power and spell damage.',\n    'Expose Armor now stacks with Sunder Armor.',\n    'Increased the value of Pick Pocketed items from rare enemies.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1125"],"export default {\n  title: 'Itemization',\n  note: '',\n  content: [\n    'Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.',\n    'Existing class sets have been reworked to better fit their class and spec.',\n    'Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.',\n    'Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.',\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1126"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n",["1127","1128"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],["1129","1130"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1131"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1132"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1133"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Wyvern Venom',\n    'spell_nature_nullifypoison',\n    ['When activated, your next succesful melee or ranged attack causes the target to fall asleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the venom causes 500 damage over 12 sec.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '115 Mana',\n    null,\n    'Instant',\n    '2 min cooldown',\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.ts",["1134"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Invigoration',\n    'ability_hunter_invigeration',\n    ['When your pet scores a critical hit with a special ability, you instantly regenerate ', '% of your maximum mana. 10 sec cooldown.'],\n    2,\n    [[5, 10]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n  new Talent('Frenzy', 'inv_misc_monsterclaw_03', ['Gives your pet a ', '% chance to gain 30% attack speed increase for 8 sec after dealing a critical strike.'], 5, [[20, 40, 60, 80, 100]], [{ x: 3, y: 2 }]),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1135"],"export default {\n  title: 'Hunter',\n  content: [\n    'New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing your ranged and melee auto attacks to regenerate mana but reducing your total damage done by 10%.  In addition, you gain 10% of maximum mana every 3 sec.  Mana gained is based on the speed of your weapon. Only one Aspect can be active at a time. Learned at lvl 40.',\n    'New ability: Steady Shot: A steady shot that causes 100% ranged weapon damage. Learned at lvl 50.',\n    'Mongoose Bite now also activates after the hunter lands a melee critical strike.',\n    'Scorpid Sting reworked: Stings the target, reducing chance to hit with melee and ranged attacks by 3% for 20 sec. Only one Sting per Hunter can be active on any one target.',\n    'Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.',\n    'Aspect of the Beast now also greatly reduces the range at which hostile beasts will attack you and your pet.',\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s attack power.\",\n    'Stable slots increased to 5.',\n    'Traps can be set while in combat, but require a 2 second arming time.',\n    'Freezing Trap will now cancel combat when cast.',\n    'Auto shot will be automatically enabled if the Hunter steps out of melee range while in combat with target.',\n    '1 Agility will now grant 1 ranged and melee attack power.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1136"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Serpent Sting', 'ability_hunter_quickshot', ['Increases the damage done by your Serpent Sting by ', '%.'], 3, [[10, 20, 30]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: false,\n  }),\n  new Talent('Improvied Scorpid Sting', 'ability_hunter_criticalshot', ['Increases the effect of your Scorpid Sting by ', '%.'], 2, [[1, 2]], null, null, null, null, null, null, null, {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1137"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Scatter Shot',\n    'ability_golemstormbolt',\n    ['A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.'],\n    1,\n    [[]],\n    null,\n    null,\n    '8% of base mana',\n    '15 yd range',\n    '30 sec cooldown'\n  ),\n  new Talent('Barrage', 'ability_upgrademoonglaive', ['Increases the damage done by your Multi-Shot and Volley spells by ', '%.'], 3, [[5, 10, 15]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent('Improved Steady Shot', 'ability_hunter_steadyshot', ['Gives your Steady Shot hits a ', '% chance to increase the damage of your next Aimed Shot or Arcane Shot by 30%.'], 3, [[5, 10, 15]], null, null, null, null, null, null, null, {\n    isNew: true,\n    isChanged: false,\n    isMoved: false,\n  }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1138"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1139"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Readiness',\n    'ability_hunter_misdirection',\n    ['Threat caused by your next 3 attacks is redirected to the target raid member. Caster and target can only be affected by one Misdirection spell at a time.  Effect lasts 30 sec.'],\n    1,\n    [[]],\n    null,\n    null,\n    '9% of base mana',\n    '100 yd range',\n    'Instant',\n    '2 min cooldown',\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent('Killer Instinct', 'spell_holy_blessingofstamina', ['Increases your critical strike chance with all attacks by ', '%.'], 3, [[1, 2, 3]], [{ x: null, y: null }], [{ x: 6, y: 1 }], null, null, null, null, ['D2']),\n  new Talent(\n    'Counterattack',\n    'ability_warrior_challange',\n    [\"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\"],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    '45 Mana',\n    'Melee range',\n    'Instant',\n    '5 sec cooldown'\n  ),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1140"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1141"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1142"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent('Improved Arcane Shot', 'ability_impalingbolt', ['Your Auto Shot hits reduce the cooldown of your Arcane Shot by ', ' sec.'], 2, [[0.25, 0.5]], null, [{ x: 2, y: 1 }], null, null, null, null, ['D1'], {\n    isNew: false,\n    isChanged: true,\n    isMoved: true,\n  }),\n  new Talent('Mortal Shots', 'ability_piercedamage', ['Increases your ranged critical strike damage bonus by ', '%.'], 5, [[6, 12, 18, 24, 39]], [{ x: 0, y: 2 }], null, null, null, null, null, null, { isNew: false, isChanged: false, isMoved: true }),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],["1143","1144"],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1145"],"import React, { useState } from 'react'\nimport { useHistory, useLocation, useParams } from 'react-router-dom'\n\nimport SelectWrapper from './talent-calculator-select'\nimport TalentCalculatorMain from './talent-calculator-main/'\nimport styles from './index.module.css'\nimport ChangedSelect from './changed-select'\nimport { PlayerClassParam, URLParams } from '../../types'\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>()\n  const history = useHistory()\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`)\n  }\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true)\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true)\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true)\n\n  const toggleIsNew = () => setIsNew(!displayIsNew)\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged)\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved)\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  }\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  }\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect toggleChangedObj={toggleChangedObj} displayChanged={displayChanged} />\n      <TalentCalculatorMain displayChanged={displayChanged} selectedClass={playerClass} />\n    </div>\n  )\n}\n\nexport default TalentCalculator\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1146"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/tale