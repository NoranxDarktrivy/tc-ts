essages":"1133","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1134","messages":"1135","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1136","messages":"1137","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1138","messages":"1139","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1140","messages":"1141","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1142","usedDeprecatedRules":"573"},{"filePath":"1143","messages":"1144","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1145","messages":"1146","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1147","usedDeprecatedRules":"586"},{"filePath":"1148","messages":"1149","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1150","usedDeprecatedRules":"573"},{"filePath":"1151","messages":"1152","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1153","usedDeprecatedRules":"573"},{"filePath":"1154","messages":"1155","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1156","usedDeprecatedRules":"573"},{"filePath":"1157","messages":"1158","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1159","messages":"1160","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1161","messages":"1162","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1163","messages":"1164","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1165","messages":"1166","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"1167","messages":"1168","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1169","messages":"1170","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1171","messages":"1172","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1173","messages":"1174","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1175","messages":"1176","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1177","messages":"1178","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1179","messages":"1180","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1181","messages":"1182","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"573"},{"filePath":"1183","messages":"1184","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1185","messages":"1186","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1187","usedDeprecatedRules":"573"},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1188","1189","1190","1191"],"import general from \"./general\";\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from \"./class-changes\";\nimport factions from \"./factions\";\nimport professions from \"./professions\";\nimport itemization from \"./itemization\";\nimport raceChanges from \"./race-changes\";\nimport designGoals from \"./design-goals\";\n// import phases from './phases'\n\nexport default {\n  title: \"Patch notes\",\n  sections: [\n    designGoals,\n    general,\n    classChanges,\n    raceChanges,\n    // factions,\n    // itemization,\n    // professions,\n  ],\n};\n",["1192","1193"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1194","1195","1196","1197"],"import world from \"./general/world\";\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from \"./general/server-balance\";\nimport worldBuffs from \"./general/world-buffs\";\nimport miscellaneous from \"./general/miscellaneous\";\n\nexport default {\n  title: \"General\",\n  content: [miscellaneous],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1198"],"export default {\n  title: \"Miscellaneous\",\n  content: [\n    \"Hit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Crit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Buff and debuff limit removed.\",\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    \"Quest log size increased.\",\n    \"Normal, elite and boss target dummies have been added to all major cities.\",\n    \"All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.\",\n    \"A disenchant option has been added to the need/greed UI.\",\n    \"The character pane now contains additional information like hit and crit.\",\n    \"Mail between characters on the same account is now instant.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Throwing weapons now often also increase the user's stats.\",\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n    \"Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.\",\n    \"Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1199"],"export default {\n  title: \"Warlock\",\n  content: [\n    \"New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone.\",\n    \"Firestone bonus Fire damage is increased and now adds fire damage to the Warlock's Wand attacks.\",\n    \"The Warlock now only takes 50% of the damage caused by Hellfire.\",\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    \"Increased Soul Shards stack size.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1200"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1201","1202"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1203"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1204"],"export default {\n  title: \"Warrior\",\n  content: [\n    \"New ability: Stance Mastery: You retain up to 10 rage points when you change stances.\",\n    \"Thunder Clap can now be used in defensive stance.\",\n    \"Slam can now be cast while moving and ignores pushback caused by damage.\",\n    \"Increased the time required for your rage to decay while out of combat 30%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1205"],"export default {\n  title: \"Priest\",\n  content: [\n    \"Damage absorbed by Power Word: Shield now scales with spell healing.\",\n    \"Fear Ward is now available to all races. Cooldown increased to 3 minutes, last 3 minutes. Fear Ward is now a discipline spell.\",\n    \"Feedback (Human) reduced mana cost and increased effect.\",\n    \"Chastise (Dwarf): new spell: Deals Holy damage and immoblizes the target, causing low theat. 20 yd range, 30 sec cooldown.\",\n    \"Elune’s Grace (Night Elf) now reduces the chance you are hit by melee or ranged attacks by 25% for 15 sec.\",\n    \"Starshards (Night Elf) now deals increased damage and lasts 4 sec. 1 min cooldown.\",\n    \"Shadowguard (Troll) orbs now look like shadow orbs instead of lightning.\",\n    \"Reduced the mana cost of Power Word: Fortitude, Prayer of Fortitude, Shadow Protection, Prayer of Shadow Protection, Divine Spirit and Prayer of Spirit.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1206"],"export default {\n  title: \"Tauren\",\n  content: [\n    \"New ability: Brawn: Increases critical strike damage and healing by 5%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1207"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1208"],"export default {\n  title: \"Paladin\",\n  content: [\n    \"New ability: Hand of Reckoning: Taunts the target to attack you. 10 sec cooldown.\",\n    \"Consecration is now a baseline ability.\",\n    \"Judgement no longer costs mana.\",\n    \"Exorcism and Holy Wrath can now be cast against any target, but always critical hit against Undead and Demon targets.\",\n    \"Seal of the Crusader reworked: Now increases attack speed by 30% and causes your attacks to deal Holy damage. Judgement effect stays the same.\",\n    \"Seal of Justice effect now stuns up to two nearby enemies.\",\n    \"Judgement of Justice now also caps the target’s movement speed at 100%.\",\n    \"Blessing of Might now also increases ranged attack power.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1209"],"export default {\n  title: \"Shaman\",\n  content: [\n    \"New ability: Totemic Recall: Removes all your totems and returns mana equal to 25% of their cost.\",\n    \"Increased the radius of totems that affect friendly targets to 30 yards.\",\n    \"Searing Totem now only attacks enemies that are in combat with the Shaman.\",\n    \"Chain Lightning and Lightning Bolt cast time reduced by 0.5 sec.\",\n    \"Stoneclaw Totem taunt effect has been greatly increased and now resets the threat on affected targets. Stoneclaw Totem now has health equal to 30% of the Shaman’s health and has a 50% chance to stun enemies that attack it.\",\n    \"Increased the slow effect of Frostbrand Weapon to 50%.\",\n    \"Stoneskin Totem now also reduces damage taken from ranged attacks.\",\n    \"Windwall Totem has been removed.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1210"],"import { Item } from './Classes'\n\nexport default [\n  new Item('Libram of Wrath', 'inv_misc_book_07', 'epic', 'Relic', 'Libram', null, null, null, null, ['Allows your Hammer of Wrath to be cast on targets with any amount of health, but reduces the damage by 95%.']),\n  new Item('Totem of Tempest', 'inv_jewelry_amulet_06', 'epic', 'Relic', 'Totem', null, null, null, null, ['Reduces the threat of additional attacks from your Windury Weapon by 75%.']),\n  new Item('Band of Guidance', 'inv_jewelry_ring_43', 'epic', 'Finger', null, null, null, null, null, ['Equip: Increases your chance to hit by 2%.', 'Equip: Increases your chance to hit with spells by 2%.']),\n  new Item('Daybreak', 'inv_hammer_04', 'epic', 'Two-hand', 'Mace', 'Speed 3.00', '131 - 255 Damage', '(59.33 damage per second)', null, ['Chance on hit: physical damage taken by target increased by 10% for 8 sec.']),\n  new Item('Idol of the World Tree', 'inv_qirajidol_night', 'rare', 'Relic', 'Idol', null, null, null, null, ['Increases the duration of your Rejuvenation and Regrowth spells by 4 sec.']),\n  new Item('Jewel of Synergy', 'inv_jewelry_ring_64', 'epic', 'Trinket', null, null, null, null, null, ['Increases your spell damage by 10% for 8 sec after dealing damage from three different magic schools within 3 sec.']),\n  new Item('Book of Command', 'warlock_grimoireofcommand', 'epic', 'Trinket', null, null, null, null, null, ['Use: Increases the damage and critical strike chance of your active pets and summons by 25% for 15 sec. (3 min cooldown)']),\n  // new Item('Totem of Tidal Orbs', 'inv_qirajidol_life', 'epic', 'Relic', 'Totem', null, null, null, null, ['Damage from your Lightning Shield returns mana equal to 60% of the damage dealt.']),\n  // new Item(\n  //   'Breastplate of Victory',\n  //   'inv_chest_plate07',\n  //   'rare',\n  //   'Chest',\n  //   'Mail',\n  //   null,\n  //   null,\n  //   null,\n  //   { armor: 207, stamina: 0, strength: 0, intellect: 0, spirit: 0, agility: 0 },\n  //   ['Gain 10 rage and 10% health after killing an opponent that yields experience or honor.'],\n  //   'Warrior',\n  //   27\n  // ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1211"],"export default {\n  title: \"Mage\",\n  content: [\n    \"New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits.\",\n    \"Amplify magic now slightly increases spell damage done. Only one can be active at a time per mage.\",\n    \"Dampen Magic is now an offensive debuff and slightly reduces damage done. Only one can be active at a time per mage.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1212"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1213"],"export default {\n  title: \"Rogue\",\n  content: [\n    \"Wound Poison effect now reduces the target's healing received by 10%, stacking up to 5 times.\",\n    \"Expose Armor now stacks with Sunder Armor.\",\n    \"Increased the value of Pick Pocketed items from rare enemies.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1214"],"export default {\n  title: \"Itemization\",\n  note: \"\",\n  content: [\n    \"Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.\",\n    \"Existing class sets have been reworked to better fit their class and spec.\",\n    \"Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1215"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1216"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1217"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Untamed\",\n    \"spell_nature_dryaddispelmagic\",\n    [\n      \"Increases your Arcane, Fire and Nature damage by up to \",\n      \"% of your attack power.\",\n    ],\n    5,\n    [[10, 20, 30, 40, 50]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Deflection\",\n    \"ability_parry\",\n    [\"Increases your parry chance by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1218"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Wyvern Sting\",\n    \"inv_spear_02\",\n    [\n      \"A stinging shot that puts the target to sleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the Sting causes 300 Nature damage over 6 sec. Only one Sting per Hunter can be active on the target at a time.\",\n    ],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    \"115 Mana\",\n    \"8 - 35 yd range\",\n    \"Instant\",\n    \"1 min cooldown\",\n    null,\n    { isNew: false, isChanged: true, isMoved: false }\n  ),\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1219"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1220"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1221"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Barrage\",\n    \"ability_upgrademoonglaive\",\n    [\n      \"Increases the damage done by your Multi-Shot and Volley spells by \",\n      \"%.\",\n    ],\n    3,\n    [[5, 10, 15]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Scatter Shot\",\n    \"ability_golemstormbolt\",\n    [\n      \"A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.\",\n    ],\n    1,\n    [[]],\n    null,\n    null,\n    \"8% of base mana\",\n    \"15 yd range\",\n    \"30 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1222"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Ranged Weapon Specialization', 'inv_weapon_rifle_06', ['Increases the damage you deal with ranged weapons by ', '%.'], 5, [[1, 2, 3, 4, 5]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1223"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Killer Instinct\",\n    \"spell_holy_blessingofstamina\",\n    [\"Increases your critical strike chance with all attacks by \", \"%.\"],\n    3,\n    [[1, 2, 3]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Counterattack\",\n    \"ability_warrior_challange\",\n    [\n      \"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\",\n    ],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    \"45 Mana\",\n    \"Melee range\",\n    \"Instant\",\n    \"5 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1224"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1225"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Trap Mastery\",\n    \"spell_nature_timestop\",\n    [\n      \"Increases the duration of your Freezing and Frost traps by \",\n      \"% and the damage of your Explosive and Immolations traps by \",\n      \"%. In addition, reduces the chance your traps are resisted by \",\n      \"%.\",\n    ],\n    2,\n    [\n      [15, 30],\n      [15, 30],\n      [5, 10],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent(\n    \"Survivalist\",\n    \"spell_shadow_twilight\",\n    [\"Increases total health by \", \"%.\"],\n    5,\n    [[2, 4, 6, 8, 10]]\n  ),\n  new Talent(\n    \"Deterrence\",\n    \"ability_whirlwind\",\n    [\"When activaed, increases dodge and parry chance by 25% for 10 sec.\"],\n    1,\n    [[]],\n    [{ x: null, y: null }],\n    [{ x: 4, y: 2 }],\n    null,\n    null,\n    \"Instant\",\n    \"5 min cooldown\",\n    [\"D2\"]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1226"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1227"],"import React, { useState } from \"react\";\nimport { useHistory, useLocation, useParams } from \"react-router-dom\";\n\nimport SelectWrapper from \"./talent-calculator-select\";\nimport TalentCalculatorMain from \"./talent-calculator-main/\";\nimport styles from \"./index.module.css\";\nimport ChangedSelect from \"./changed-select\";\nimport { PlayerClassParam, URLParams } from \"../../types\";\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>();\n  const history = useHistory();\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`);\n  };\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true);\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true);\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true);\n\n  const toggleIsNew = () => setIsNew(!displayIsNew);\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged);\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved);\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  };\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  };\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect\n        toggleChangedObj={toggleChangedObj}\n        displayChanged={displayChanged}\n      />\n      <TalentCalculatorMain\n        displayChanged={displayChanged}\n        selectedClass={playerClass}\n      />\n    </div>\n  );\n};\n\nexport default TalentCalculator;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1228"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/s