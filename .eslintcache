140","usedDeprecatedRules":"574"},{"filePath":"1141","messages":"1142","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1143","messages":"1144","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1145","usedDeprecatedRules":"587"},{"filePath":"1146","messages":"1147","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1148","usedDeprecatedRules":"574"},{"filePath":"1149","messages":"1150","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1151","usedDeprecatedRules":"574"},{"filePath":"1152","messages":"1153","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1154","usedDeprecatedRules":"574"},{"filePath":"1155","messages":"1156","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1157","messages":"1158","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1159","messages":"1160","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1161","messages":"1162","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1163","messages":"1164","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1165","messages":"1166","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1167","messages":"1168","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1169","messages":"1170","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1171","messages":"1172","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1173","messages":"1174","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1175","messages":"1176","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1177","messages":"1178","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1179","messages":"1180","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"574"},{"filePath":"1181","messages":"1182","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"1183","usedDeprecatedRules":"574"},{"filePath":"1184","messages":"1185","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1186","messages":"1187","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"1188","messages":"1189","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/index.ts",["1190","1191","1192","1193"],"import general from \"./general\";\n// import pveContent from './pve-content'\n// import pvpContent from './pvp-content'\nimport classChanges from \"./class-changes\";\nimport factions from \"./factions\";\nimport professions from \"./professions\";\nimport itemization from \"./itemization\";\nimport raceChanges from \"./race-changes\";\nimport designGoals from \"./design-goals\";\n// import phases from './phases'\n\nexport default {\n  title: \"Patch notes\",\n  sections: [\n    designGoals,\n    general,\n    classChanges,\n    raceChanges,\n    // factions,\n    // itemization,\n    // professions,\n  ],\n};\n",["1194","1195"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/index.tsx",["1196","1197","1198","1199"],"import world from \"./general/world\";\n// import badgeOfJustice from './general/badge-of-justice'\n// import heroic from './general/heroic'\nimport serverBalance from \"./general/server-balance\";\nimport worldBuffs from \"./general/world-buffs\";\nimport miscellaneous from \"./general/miscellaneous\";\n\nexport default {\n  title: \"General\",\n  content: [miscellaneous],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/miscellaneous.ts",["1200"],"export default {\n  title: \"Miscellaneous\",\n  content: [\n    \"Hit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Crit chance now applies to both spells and physical attacks unless otherwise specified.\",\n    \"Buff and debuff limit removed.\",\n    \"A disenchant option has been added to the need/greed UI.\",\n    \"Mail between characters on the same account is now instant.\",\n    \"Melee and ranged auto attack now automatically toggle.\",\n    \"The character pane now contains additional information like hit and crit.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Throwing weapons now often also increase the user's stats.\",\n    \"Vendors now sell drinks that restore mana equal to mage’s Conjured Crystal Water.\",\n    \"Vendors now sell food that restores health equal to mage’s Conjured Cinnamon Roll.\",\n    \"All gathering professions can now be learned in Elwynn Forest, Dun Morogh, Teldrassil, Durotar, Mulgore and Tirisfal Glades. This means players no longer have to travel to a Capital City to learn these professions.\",\n    \"Quest log size increased.\",\n    \"Normal, elite and boss target dummies have been added to all major cities.\",\n    'A \"duel as party\" option has been added from the character dropdown menu for party leaders. This allows parties to duel each other.',\n    \"The boats that travel between Ruth'eran Village - Auberdine and Feralas coast - Feathermoon Stronghold now have the Night Elf boat model.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock.ts",["1201"],"export default {\n  title: \"Warlock\",\n  content: [\n    \"New ability: Ritual of Souls. Creates a Soulwell with Healthstones. Party and raid members can click on the well to acquire a Healthstone.\",\n    \"New ability: Soulshatter: Reduces threat by 50% for all enemies within 40 yards. Reagents: Soul Shard. 5 min cooldown.\",\n    \"Life Tap now grants more mana at the cost of health.\",\n    \"Demon Armor now increases healing taken by 20% instead of health over time.\",\n    \"Firestone bonus Fire damage is increased and now adds fire damage to the Warlock's Wand attacks.\",\n    \"Rain of Fire and Hellfire damage increased.\",\n    \"All demons will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master’s spell damage.\",\n    \"Increased Soul Shards stack size.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world-buffs.ts",["1202"],"export default {\n  title: 'World buffs',\n  content: [\n    'New world buff: Champion of the Alliance / Champion of the Horde: Increases critical strike chance by 5% and increases damage and healing by 10%. Lasts 120 min. This buff can be purchased Stormwind and Orgrimmar once a prequest has been completed. Three days cooldown.',\n    'Rallying Cry of the Dragonslayer: Now increases reputation and experience gained by 10%.',\n    'Songflower Serenade: Now only active in Felwood and Winterspring.',\n    \"Spirit of Zandalar: Now only active in Stranglethorn Vale and Zul'Gurub.\",\n    \"Warchief's Blessing: Now only active in Horde territory\",\n    'Dire Maul North buffs: Removed.',\n  ],\n}\n",["1203","1204"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/factions/index.ts",["1205"],"export default {\n  title: 'Factions',\n  note: '',\n  content: [\n    'Vendors have been added for all capital city factions. These vendors sell various items, recipes and enchants. Many of these items and enchants require specific reputation.',\n    'Capital city reputation can be gained by turning in resources like copper ore, silk cloth, arcane dust, thick leather, et cetera.',\n    \"Players can also earn reputation with capital cities by wearing the city's tabard while participating in dungeons or raids.\",\n    'Reputation gained from leveling quests has been adjusted.',\n    'Battleground faction vendors now sell additional equipment, in exchange for Marks of Honor in addition to gold.',\n    'Players can earn additional reputation with battleground factions by wearing the faction’s tabard while gaining honor.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warrior.ts",["1206"],"export default {\n  title: \"Warrior\",\n  content: [\n    \"New ability: Stance Mastery: You retain up to 10 rage points when you change stances.\",\n    \"Thunder Clap can now be used in defensive stance.\",\n    \"Slam can now be cast while moving and ignores pushback caused by damage.\",\n    \"Increased the damage dealt by Rend.\",\n    \"Increased the time required for your rage to decay while out of combat 30%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier4.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/priest.ts",["1207"],"export default {\n  title: \"Priest\",\n  content: [\n    \"Damage absorbed by Power Word: Shield now scales with spell healing.\",\n    \"Fear Ward is now available to all races. Cooldown increased to 3 minutes, last 3 minutes. Fear Ward is now a discipline spell.\",\n    \"Feedback (Human) reduced mana cost and increased effect.\",\n    \"Chastise (Dwarf): new spell: Deals Holy damage and immoblizes the target, causing low theat. 20 yd range, 30 sec cooldown.\",\n    \"Elune’s Grace (Night Elf) now reduces the chance you are hit by melee or ranged attacks by 25% for 15 sec.\",\n    \"Starshards (Night Elf) now deals increased damage and lasts 4 sec. 1 min cooldown.\",\n    \"Shadowguard (Troll) orbs now look like shadow orbs instead of lightning.\",\n    \"Reduced the mana cost of Power Word: Fortitude, Prayer of Fortitude, Shadow Protection, Prayer of Shadow Protection, Divine Spirit and Prayer of Spirit.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/tauren.tsx",["1208"],"export default {\n  title: \"Tauren\",\n  content: [\n    \"New ability: Brawn: Increases critical strike damage and healing by 5%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/druid.ts",["1209"],"export default {\n  title: \"Druid\",\n  content: [\n    \"New ability: Lacerate: Lacerates the enemy target, dealing damage and bleeds the target over 15 sec and causing a high amount of threat. This effect stacks up to 5 times on the same target\",\n    \"Tiger’s Fury reworked: now returns 50 energy and increases the damage of your next ability while in cat form by 25%. 30 sec cooldown.\",\n    \"Faerie Fire no longer costs mana, now has a 6 second cooldown and can be used in all forms.\",\n    \"Cat Form now has a separate action bar when prowling.\",\n    \"Swipe now scales with attack power.\",\n    \"Frenzied Regeneration now heals based on the druid's total health.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    \"Rejuvenation and Regrowth spells can now be active on targets affected by another Druid's Rejuvenation or Regrowth.\",\n    \"Reduced the mana cost of Mark of the Wild and Gift of the Wild.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/paladin.ts",["1210"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/shaman.ts",["1211"],"export default {\n  title: \"Shaman\",\n  content: [\n    \"New ability: Totemic Recall: Removes all your totems and returns mana equal to 25% of their cost.\",\n    \"Increased the radius of totems that affect friendly targets to 30 yards.\",\n    \"Searing Totem now only attacks enemies that are in combat with the Shaman.\",\n    \"Stoneclaw Totem taunt effect has been greatly increased and now resets the threat on affected targets. Stoneclaw Totem now has health equal to 30% of the Shaman’s health and has a 50% chance to stun enemies that attack it.\",\n    \"Flametongue, Frostbrand, Rockbiter and Windfury Weapon effects and Flametongue and Windfury Totem effects are now catagorized as generic buffs instead of weapon buffs.\",\n    \"Stoneskin Totem now also reduces damage taken from ranged attacks.\",\n    \"Windwall Totem has been removed.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/section.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/changed-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/create-talents.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/index.tsx",["1212"],"import { Item } from './Classes'\n\nexport default [\n  new Item('Libram of Wrath', 'inv_misc_book_07', 'epic', 'Relic', 'Libram', null, null, null, null, ['Allows your Hammer of Wrath to be cast on targets with any amount of health, but reduces the damage by 95%.']),\n  new Item('Totem of Tempest', 'inv_jewelry_amulet_06', 'epic', 'Relic', 'Totem', null, null, null, null, ['Reduces the threat of additional attacks from your Windury Weapon by 75%.']),\n  new Item('Band of Guidance', 'inv_jewelry_ring_43', 'epic', 'Finger', null, null, null, null, null, ['Equip: Increases your chance to hit by 2%.', 'Equip: Increases your chance to hit with spells by 2%.']),\n  new Item('Daybreak', 'inv_hammer_04', 'epic', 'Two-hand', 'Mace', 'Speed 3.00', '131 - 255 Damage', '(59.33 damage per second)', null, ['Chance on hit: physical damage taken by target increased by 10% for 8 sec.']),\n  new Item('Idol of the World Tree', 'inv_qirajidol_night', 'rare', 'Relic', 'Idol', null, null, null, null, ['Increases the duration of your Rejuvenation and Regrowth spells by 4 sec.']),\n  new Item('Jewel of Synergy', 'inv_jewelry_ring_64', 'epic', 'Trinket', null, null, null, null, null, ['Increases your spell damage by 10% for 8 sec after dealing damage from three different magic schools within 3 sec.']),\n  new Item('Book of Command', 'warlock_grimoireofcommand', 'epic', 'Trinket', null, null, null, null, null, ['Use: Increases the damage and critical strike chance of your active pets and summons by 25% for 15 sec. (3 min cooldown)']),\n  // new Item('Totem of Tidal Orbs', 'inv_qirajidol_life', 'epic', 'Relic', 'Totem', null, null, null, null, ['Damage from your Lightning Shield returns mana equal to 60% of the damage dealt.']),\n  // new Item(\n  //   'Breastplate of Victory',\n  //   'inv_chest_plate07',\n  //   'rare',\n  //   'Chest',\n  //   'Mail',\n  //   null,\n  //   null,\n  //   null,\n  //   { armor: 207, stamina: 0, strength: 0, intellect: 0, spirit: 0, agility: 0 },\n  //   ['Gain 10 rage and 10% health after killing an opponent that yields experience or honor.'],\n  //   'Warrior',\n  //   27\n  // ),\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/lib/handle-talents.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/example-items/Classes.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/tc-patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/mage.ts",["1213"],"export default {\n  title: \"Mage\",\n  content: [\n    \"New ability: Frostfire Bolt: Launches a bolt of frostfire at the enemy, causing Frostfire damage, slowing movement speed by 40% and causing an additionaldamage over 9 sec. This spell will be checked against the lower of the target's Frost and Fire resists.\",\n    \"New ability: Ritual of Refreshment: Creates a table with Mana Biscuits. Raid members can click on the table to acquire Conjured Mana Biscuits.\",\n    \"Amplify magic now slightly increases spell damage done. Only one can be active at a time per mage.\",\n    \"Dampen Magic is now an offensive debuff and slightly reduces damage done. Only one can be active at a time per mage.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/warlock-demons.ts",["1214"],"export default {\n  title: 'Warlock demons',\n  content: ['Felhunter now gains mana from auto attacks.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/rogue.ts",["1215"],"export default {\n  title: \"Rogue\",\n  content: [\n    \"Wound Poison effect now reduces the target's healing received by 10%, stacking up to 5 times.\",\n    \"Throwing Weapons can now be poisoned.\",\n    \"Increased the value of Pick Pocketed items from rare enemies.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/itemization/index.ts",["1216"],"export default {\n  title: \"Itemization\",\n  note: \"\",\n  content: [\n    \"Many 2, 3, 4 and 5-part sets have been added, along with single items. Many of these sets and items encourage niche and uncommon builds.\",\n    \"Existing class sets have been reworked to better fit their class and spec.\",\n    \"Additional items and sets rewarded for honor have been added or changed to better fit various classes and specs.\",\n    \"Throwing weapons items no longer stack, but lose durability when thrown instead. These throwing weapons can be repaired. Some throwing weapons have unique effects, like poisoning the target, or bouncing off of enemies.\",\n    \"Several weapons that increase a druid's attack power while in cat, bear and dire bear forms have been added.\",\n    // 'Incomplete items and recipes can now be obtained from various sources, like bosses, chests and world drops. Collect resources and complete quests to obtain the complete items and recipes.',\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/world.ts",["1217"],"export default {\n  title: 'World',\n  content: [\n    'Additional rare mobs and rare bosses now spawn in all zones. These mobs and bosses drop valuable items and resources. This should encourage players to venture out more into the world and engage in world PvP.',\n    'Rare mobs now have improved loot tables.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/arrow.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier4.ts",["1218"],"import { Talent } from '../../Classes'\n\nexport default [\n  new Talent(\n    'Improved Feign Death',\n    'ability_rogue_feigndeath',\n    ['Reduces the cooldown of your Feign Death by ', ' sec and reduces the chance your Feign Death is resisted by ', '%.'],\n    2,\n    [\n      [2, 4],\n      [2, 4],\n    ],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: false,\n      isChanged: true,\n      isMoved: false,\n    }\n  ),\n  new Talent('Surefooted', 'ability_kick', ['Increases hit chance by ', '% and increases the chance you resist movement impairing efects by ', '%.'], 3, [\n    [1, 2, 3],\n    [5, 10, 15],\n  ]),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier1.ts",["1219"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Monster Slaying\",\n    \"inv_misc_head_dragon_black\",\n    [\n      \"Increases all damage caused against Beasts, Giants and Dragonkin targets by 3% and increases critical damage caused against Beasts, Giants and Dragonkin targets by an additional \",\n      \"%.\",\n    ],\n    3,\n    [[1, 2, 3]]\n  ),\n  new Talent(\n    \"Humanoid Slaying\",\n    \"spell_holy_prayerofhealing\",\n    [\n      \"Increases all damage caused against Humanoid targets by 3% and increases critical damage caused against Humanoid targets by an additional \",\n      \"%.\",\n    ],\n    3,\n    [[1, 2, 3]]\n  ),\n  new Talent(\n    \"Deflection\",\n    \"ability_parry\",\n    [\"Increases your parry chance by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier7.ts",["1220"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Carve\",\n    \"inv_throwingknife_06\",\n    [\n      \"A sweeping attack that strikes all enemies in front of you with your melee weapons for 100% weapon damage and increases the attack speed of party members within 40 yards by 10% for 6 sec.\",\n    ],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    \"4% of base mana\",\n    \"Melee range\",\n    \"Instant\",\n    \"12 sec cooldown\",\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  null,\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier7.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter.ts",["1221"],"export default {\n  title: \"Hunter\",\n  content: [\n    \"New ability: Steady Shot: A steady shot that causes base weapon damage plus additional damage.\",\n    \"New ability: Aspect of the Viper: The hunter takes on the aspect of the viper, causing ranged and melee attacks to regenerate mana but reducing your total damage done by 50%. In addition, you gain 4% of maximum mana every 3 sec.\",\n    \"All pets will now receive a percentage of their master's stats and their spell damage and attack power is increased by a percentage of their master's attack power.\",\n    \"Hunters now gain 1 ranged and melee attack power for each point of agility.\",\n    \"Traps can now be used while in combat, but have a 2 second arm time.\",\n    \"Mongoose Bite damage increased.\",\n    \"Aspect of the Beast reworked: now also increases the melee attack power of the hunter and the hunter's pet.\",\n    \"Aspect of the Wild now also makes affected targets untrackable.\",\n    \"Mend pet is now instant cast and has 40 yard range. It is still a heal over time effect.\",\n    \"Number of stable slots increased.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier4.ts",["1222"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Improved Steady Shot\",\n    \"ability_hunter_improvedsteadyshot\",\n    [\n      \"When you Steady Shot twice in a row, your ranged attack speed will be increased by \",\n      \"% for 8 sec.\",\n    ],\n    3,\n    [[5, 10, 15]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Mortal Shots\",\n    \"ability_piercedamage\",\n    [\"Increases your ranged critical strike damage bonus by \", \"%.\"],\n    3,\n    [[10, 20, 30]],\n    [{ x: 1, y: 2 }],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: false, isChanged: true, isMoved: false }\n  ),\n  null,\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier5.ts",["1223"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Scatter Shot\",\n    \"ability_golemstormbolt\",\n    [\n      \"A short-range shot that deals 50% weapon damage and disorients the target for 4 sec. Any damage caused will remove the effect. Turns off your attack when used.\",\n    ],\n    1,\n    [[]],\n    null,\n    null,\n    \"8% of base mana\",\n    \"15 yd range\",\n    \"30 sec cooldown\"\n  ),\n  new Talent(\n    \"Barrage\",\n    \"ability_upgrademoonglaive\",\n    [\n      \"Increases the damage done by your Multi-Shot and Volley spells by \",\n      \"%.\",\n    ],\n    3,\n    [[5, 10, 15]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Improved Scorpid Sting\",\n    \"ability_hunter_criticalshot\",\n    [\"Increases the effect of your Scorpid Sting by \", \"%.\"],\n    3,\n    [[10, 20, 30]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: false, isChanged: true, isMoved: false }\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier6.ts",["1224"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  null,\n  new Talent(\n    \"Ranged Weapon Specialization\",\n    \"inv_weapon_rifle_06\",\n    [\"Increases the damage you deal with ranged weapons by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier5.ts",["1225"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Wyvern Sting\",\n    \"inv_spear_02\",\n    [\n      \"A stinging shot that puts the target to sleep for 12 sec. Any damage will cancel the effect. When the target wakes up, the Sting causes 300 Nature damage over 6 sec. Only one Sting per Hunter can be active on the target at a time.\",\n    ],\n    1,\n    [[]],\n    null,\n    null,\n    \"115 Mana\",\n    \"8 - 35 yd range\",\n    \"3 sec cast\",\n    \"2 min cooldown\",\n    null,\n    { isNew: false, isChanged: true, isMoved: true }\n  ),\n  new Talent(\n    \"Killer Instinct\",\n    \"spell_holy_blessingofstamina\",\n    [\"Increases your critical strike chance with all attacks by \", \"%.\"],\n    3,\n    [[1, 2, 3]],\n    [{ x: null, y: null }],\n    [{ x: 6, y: 1 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  new Talent(\n    \"Counterattack\",\n    \"ability_warrior_challange\",\n    [\n      \"A strike that becomes active after parrying an opponent's attack. This attack deals 40 damage and immobilizes the target for 5 sec. Counterattack cannot be blocked, dodged, or parried.\",\n    ],\n    1,\n    [[]],\n    [{ x: 2, y: 2 }],\n    null,\n    \"45 Mana\",\n    \"Melee range\",\n    \"Instant\",\n    \"5 sec cooldown\"\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier6.ts",["1226"],"import { Talent } from '../../Classes'\n\nexport default [null, null, new Talent('Lightning Reflexes', 'spell_nature_invisibilty', ['Increases your agility by ', '%.'], 5, [[3, 6, 9, 12, 15]]), null]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier3.ts",["1227"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier2.ts",["1228"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  new Talent(\n    \"Improved Arcane Shot\",\n    \"ability_impalingbolt\",\n    [\n      \"Your ranged attacks reduce the cooldown of your Arcane Shot by \",\n      \" sec.\",\n    ],\n    3,\n    [[0.3, 0.6, 1]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    { isNew: false, isChanged: true, isMoved: true }\n  ),\n  new Talent(\n    \"Improved Hunter's Mark\",\n    \"ability_hunter_snipershot\",\n    [\n      \"Increases the Ranged Attack Power bonus of your Hunter's Mark spell by \",\n      \"%.\",\n    ],\n    5,\n    [[3, 6, 9, 12, 15]]\n  ),\n  new Talent(\n    \"Lethal Shots\",\n    \"ability_searingarrow\",\n    [\"Increases your critical strike chance with ranged weapons by \", \"%.\"],\n    5,\n    [[1, 2, 3, 4, 5]],\n    [{ x: null, y: null }],\n    [{ x: 3, y: 2 }],\n    null,\n    null,\n    null,\n    null,\n    [\"D2\"]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/index.tsx",["1229"],"import React, { useState } from \"react\";\nimport { useHistory, useLocation, useParams } from \"react-router-dom\";\n\nimport SelectWrapper from \"./talent-calculator-select\";\nimport TalentCalculatorMain from \"./talent-calculator-main/\";\nimport styles from \"./index.module.css\";\nimport ChangedSelect from \"./changed-select\";\nimport { PlayerClassParam, URLParams } from \"../../types\";\n\nconst TalentCalculator: React.FC = () => {\n  const { playerClass } = useParams<URLParams>();\n  const history = useHistory();\n\n  const selectClass = (clickedClass: PlayerClassParam) => {\n    history.replace(`/tc/${clickedClass}`);\n  };\n\n  const [displayIsNew, setIsNew] = useState<boolean>(true);\n  const [displayIsChanged, setIsChanged] = useState<boolean>(true);\n  const [displayIsMoved, setIsMoved] = useState<boolean>(true);\n\n  const toggleIsNew = () => setIsNew(!displayIsNew);\n  const toggleIsChanged = () => setIsChanged(!displayIsChanged);\n  const toggleIsMoved = () => setIsMoved(!displayIsMoved);\n\n  const displayChanged = {\n    displayIsNew,\n    displayIsChanged,\n    displayIsMoved,\n  };\n\n  const toggleChangedObj = {\n    toggleIsChanged,\n    toggleIsNew,\n    toggleIsMoved,\n  };\n\n  return (\n    <div className={styles.tcWrapper}>\n      <SelectWrapper selectClass={selectClass} selectedClass={playerClass} />\n      <ChangedSelect\n        toggleChangedObj={toggleChangedObj}\n        displayChanged={displayChanged}\n      />\n      <TalentCalculatorMain\n        displayChanged={displayChanged}\n        selectedClass={playerClass}\n      />\n    </div>\n  );\n};\n\nexport default TalentCalculator;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/gnome.tsx",["1230"],"export default {\n  title: 'Gnome',\n  content: ['New ability: Nimble Fingers: Your attacks ignore armor equal to your level.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/changed-bar.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier1.ts",["1231"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Improved Aspect of the Hawk\",\n    \"spell_nature_ravenform\",\n    [\n      \"While Aspect of the Hawk is active, all normal ranged attacks have a \",\n      \"% chance to increase your ranged attack speed by 30% for 12 sec.\",\n    ],\n    5,\n    [[1, 2, 3, 4, 5]]\n  ),\n  new Talent(\n    \"Improved Aspect of the Beast\",\n    \"ability_mount_pinktiger\",\n    [\n      \"While Aspect of the Beast is active, critical strikes from your pet's abilities have a \",\n      \"% chance to enable your Mongoose Bite.\",\n    ],\n    5,\n    [[10, 20, 30, 40, 50]],\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    null,\n    {\n      isNew: true,\n      isChanged: false,\n      isMoved: false,\n    }\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/Classes.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/tier2.ts",["1232"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier6.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/undead.tsx",["1233"],"export default {\n  title: \"Undead\",\n  content: [\n    \"New ability: Embrace of Undeath: Deal 10% additional damage to targets below 10% health.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier4.ts",["1234"],"import { Talent } from '../../Classes'\nexport default [\n  null,\n  new Talent('Caretaker', 'ability_hunter_mendpet', ['Gives your Mend Pet spell a ', '% chance to remove 1 poison, disease, curse of magic effect from your pet each tick.'], 2, [[15, 30]]),\n  new Talent('Ferocity', 'inv_misc_monsterclaw_04', ['Increases the critical strike chance of your pets by ', '%.'], 5, [[3, 6, 9, 12, 15]], [{ x: null, y: null }], [{ x: 5, y: 2 }], null, null, null, null, ['D2']),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/reportWebVitals.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/human.tsx",["1235"],"export default {\n  title: \"Human\",\n  content: [\n    \"Mace Specialization removed.\",\n    \"The Human Spirit now allows 5% of your Mana regeneration to continue while casting.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/general/general/server-balance.ts",["1236"],"export default {\n  title: 'Server Balance',\n  content: [\n    'On servers where one faction is underrepresented, players of that faction gain bonus experience and reputation in proportion to this underrepresentation. This should encourage players to choose servers and factions with population issues.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/App.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/nav-bar/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/troll.tsx",["1237"],"export default {\n  title: \"Troll\",\n  content: [\n    \"New ability: Da Voodoo Shuffle: Reduces the duration of all movement impairing effects by 15%.  Trolls be flippin' out mon!\",\n    \"Troll Regeneration now restores 1% health every 5 seconds.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier7.ts",["1238"],"import { Talent } from '../../Classes'\n\nexport default [\n  null,\n  new Talent(\n    'Bestial Wrath',\n    'ability_druid_ferociousbite',\n    ['Send your pet into a rage causing 50% additional damage for 18 sec. While enraged, the beast does not feel pity or remorse or fear and it cannot be stopped unless killed.'],\n    1,\n    [[]],\n    [{ x: 4, y: 1 }],\n    null,\n    '12% of base mana',\n    '100 yd range',\n    'Instant',\n    '2 min cooldown'\n  ),\n  null,\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier1.ts",["1239"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Improved Concussive Shot\",\n    \"spell_frost_stun\",\n    [\"Gives your Concussive Shot a \", \"% chance to stun the target for 3 sec.\"],\n    5,\n    [[4, 8, 12, 16, 20]]\n  ),\n  new Talent(\n    \"Efficiency\",\n    \"spell_frost_wizardmark\",\n    [\"Reduces the Mana cost of your Shots and Stings by \", \"%.\"],\n    5,\n    [[2, 4, 6, 8, 10]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/dwarf.tsx",["1240"],"export default {\n  title: 'Dwarf',\n  content: ['New ability: Mace Specialization: Increases your skill with maces by 5.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/survival/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier5.ts",["1241"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/tooltip.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-select/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/patch-notes/paragraph.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/grid/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/arms/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier5.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier7.ts",["1242"],"import { Talent } from \"../../Classes\";\n\nexport default [\n  null,\n  new Talent(\n    \"Trueshot Aura\",\n    \"ability_trueshot\",\n    [\n      \"Increases the attack power of party members within 45 yards by 50. Lasts 30 min.\",\n    ],\n    1,\n    [[]],\n    [{ x: 4, y: 2 }],\n    null,\n    \"325 Mana\",\n    null,\n    \"Instant\"\n  ),\n  null,\n  null,\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/balance/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-main/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier3.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/example-items/single-item.tsx",["1243"],"import React from \"react\";\n\nimport { Item } from \"../../data/example-items/Classes\";\nimport { getClassColor } from \"../../lib/ui-utils\";\nimport { PlayerClassParam, Stats } from \"../../types\";\nimport styles from \"./index.module.css\";\n\nconst SingleItemIcon: React.FC<{ img: string }> = ({ img }) => {\n  return (\n    <div className={styles.singleItemIconWrapper}>\n      <div\n        className={styles.singleItemHighlight}\n        style={{\n          backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border-large.png\")`,\n        }}\n      />\n      <div\n        className={styles.singleItemIcon}\n        style={{\n          background: `url(\"https://wow.zamimg.com/images/wow/icons/large/${img}.jpg\") 0 0 no-repeat`,\n        }}\n      />\n      <div />\n    </div>\n  );\n};\n\nconst ItemName: React.FC<{ name: string; quality: string }> = ({\n  name,\n  quality,\n}) => {\n  const color = quality === \"epic\" ? \"#a335ee\" : \"#0070dd\";\n  return (\n    <div className={styles.itemName} style={{ color }}>\n      {name}\n    </div>\n  );\n};\n\nconst ItemSlot: React.FC<{\n  slot: string;\n  itemType: string | null | undefined;\n}> = ({ slot, itemType }) => {\n  return (\n    <div className={styles.singleItemFlex}>\n      <div>{slot}</div>\n      <div>{itemType}</div>\n    </div>\n  );\n};\n\nconst ItemDmg: React.FC<{\n  damage: string | null | undefined;\n  speed: string | null;\n  dps: string | null;\n}> = ({ damage, speed, dps }) => {\n  return (\n    <>\n      <div className={styles.singleItemFlex}>\n        <div>{speed}</div>\n        <div>{damage}</div>\n      </div>\n      <div className={styles.singleItemFlex}>{dps}</div>\n    </>\n  );\n};\n\nconst SingleStat: React.FC<{ stat: string; value: number }> = ({\n  stat,\n  value,\n}) => {\n  const sign = value < 0 ? \"-\" : \"+\";\n  const capitalKey = stat?.charAt(0).toUpperCase() + stat?.slice(1);\n\n  return (\n    <div className={styles.singleItemFlex}>\n      {sign}\n      {value} {capitalKey}\n    </div>\n  );\n};\n\nconst ItemStats: React.FC<{ stats: Stats }> = ({ stats }) => {\n  return (\n    <>\n      {Object.entries(stats).map(([stat, value], index) => {\n        if (!!value)\n          return <SingleStat key={index} stat={stat} value={value} />;\n      })}\n    </>\n  );\n};\n\nconst SingleItem: React.FC<Item> = ({\n  name,\n  img,\n  quality,\n  slot,\n  itemType,\n  damage,\n  speed,\n  dps,\n  stats,\n  description,\n  playerClass,\n  levelRequired,\n}) => {\n  const hasDmg = damage && speed && dps;\n\n  return (\n    <div className={styles.singleItemWrapper}>\n      <SingleItemIcon img={img} />\n      <div\n        className={styles.singleItemDescription}\n        style={{\n          backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/background/tooltip.png\")`,\n        }}\n      >\n        <ItemName name={name} quality={quality} />\n        <ItemSlot slot={slot} itemType={itemType} />\n        {hasDmg && <ItemDmg damage={damage} speed={speed} dps={dps} />}\n        {stats && <ItemStats stats={stats} />}\n        {playerClass && (\n          <div className={styles.singleItemPlayerClass}>\n            Classes:{\" \"}\n            <span\n              style={{\n                color: getClassColor(\n                  playerClass.toLowerCase() as PlayerClassParam\n                ),\n              }}\n            >\n              {playerClass}\n            </span>\n          </div>\n        )}\n        <div className={styles.itemDescription}>\n          {description &&\n            description.map((line, i) => <div key={i}>{line}</div>)}\n        </div>\n        {levelRequired && (\n          <div className={styles.singleItemPlayerClass}>\n            Requires level {levelRequired}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n};\n\nexport default SingleItem;\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/cell/index.tsx",["1244"],"import React, { useState } from 'react'\n\nimport { Talent } from '../../../data/talents/Classes'\nimport Tooltip from './tooltip'\nimport Arrow from './arrow'\nimport styles from './cell.module.css'\nimport ChangedBar from './changed-bar'\nimport { useParams } from 'react-router-dom'\nimport { URLParams } from '../../../types'\n\ninterface CellProps {\n  cellData: Talent\n  i: number\n  x: number\n  y: number\n  color: string | null\n  clickHandler: (i: number, x: number, y: number, e: React.MouseEvent<HTMLElement>) => void\n  displayChanged: {\n    displayIsNew: boolean\n    displayIsChanged: boolean\n    displayIsMoved: boolean\n  }\n}\n\nconst Cell: React.FC<CellProps> = ({ cellData, i, x, y, color, clickHandler, displayChanged }) => {\n  const { talentPoints } = useParams<URLParams>()\n  const [showTooltip, set_showTooltip] = useState<boolean>(false)\n  const { value, maxValue, icon, manaCost, range, castTime, cooldown, name, arrows, changed } = cellData\n\n  const borderColor = !!color ? `2px solid ${color}` : `2px solid black`\n  const cellFilter = !color ? 'grayscale(100%)' : 'none'\n\n  // yes: value\n\n  return (\n    <div\n      className={styles.cellWrapper}\n      onMouseEnter={() => {\n        set_showTooltip(true)\n      }}\n      onMouseLeave={() => {\n        set_showTooltip(false)\n      }}>\n      <ChangedBar displayChanged={displayChanged} changed={changed} />\n      <div className={styles.cellHighlight} style={{ backgroundImage: `url(\"${process.env.PUBLIC_URL}/img/icons/border.png\")` }} />\n      <div\n        style={{\n          background: `url(\"https://wow.zamimg.com/images/wow/icons/medium/${icon}.jpg\") 0 0 no-repeat`,\n          border: borderColor,\n          filter: cellFilter,\n        }}\n        className={styles.cellIconStyle}>\n        <button\n          className={styles.cellButtonStyle}\n          onClick={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}\n          onContextMenu={(e: React.MouseEvent<HTMLElement>) => {\n            clickHandler(i, x, y, e)\n          }}>\n          <div className={styles.cellPointsStyle} style={{ color: color ? 'white' : '#787878' }}>\n            {`${value}/${maxValue}`}\n          </div>\n        </button>\n      </div>\n      {showTooltip && <Tooltip value={cellData.value} description={cellData.description} maxValue={cellData.maxValue} valueIteration={cellData.valueIteration} manaCost={manaCost} range={range} castTime={castTime} cooldown={cooldown} name={name} />}\n      {arrows &&\n        arrows.map((arrow, i) => {\n          return <Arrow arrowData={arrow} color={color} key={i} />\n        })}\n    </div>\n  )\n}\n\nexport default Cell\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/discipline/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/elemental/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier5.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/night-elf.tsx",["1245"],"export default {\n  title: \"Night Elf\",\n  content: [\n    \"New ability: Elusiveness: Increases stealth level by 1 and movement speed while stealthed by 5%.\",\n    \"Shadowmeld no longer increases stealth level.\",\n    \"Quickness now also increase attack speed by 1%.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/orc.tsx",["1246"],"export default {\n  title: 'Orc',\n  content: ['Blood Fury: now also increases your spell damage and healing and ranged attack power.'],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/retribution/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/ui-utils.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/lib/talents-url.tsx",["1247","1248"],"import { Talent } from '../data/talents/Classes'\nimport { ClassSpecType, ClassTalentType } from '../types'\n\nconst flattenSpec = (specData: ClassSpecType) => {\n  return specData.flatMap(row => row)\n}\n\nexport const flattenTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return talentData.flatMap(flattenSpec)\n}\n\nexport const getFlattenedTalentValues = (talentData: ClassTalentType | null) => {\n  const flattenedTalents = flattenTalents(talentData)\n  return flattenedTalents.map(talent => talent?.value).filter(talent => !isNaN(talent!))\n}\n\nconst getTruthyTalents = (talentData: ClassTalentType | null) => {\n  if (!talentData) return []\n  return flattenTalents(talentData).filter(talent => talent)\n}\n\nconst loopURLTalents = (flatTalents: (Talent | null)[], talentsFromUrl: string) => {\n  let stringIndex: number = 0\n\n  for (let i = 0; i < flatTalents.length; i++) {\n    if (!!flatTalents[i]) {\n      flatTalents[i]?.setValue(parseInt(talentsFromUrl[stringIndex]))\n      stringIndex++\n    }\n  }\n}\n\n// http://localhost:3000/tc-ts#/tc/druid/0140003000000000050023011000000000055003115010000\n\nexport const loopTalentsFromUrl = (talentData: ClassTalentType | null, talentPoints: string) => {\n  if (!talentData) return []\n\n  let stringIndex: number = 0\n\n  talentData.forEach(spec => {\n    spec.forEach(row => {\n      row.forEach(cell => {\n        if (!!cell) {\n          cell.setValue(parseInt(talentPoints[stringIndex]))\n          stringIndex++\n        }\n      })\n    })\n  })\n\n  return talentData\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/components/talent-calculator/talent-calculator-footer/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/professions/index.ts",["1249"],"export default {\n  title: 'Professions',\n  note: '',\n  content: [\n    'Players can now select their profession and rank as title. For example “Artisan Blacksmith [Name]”.',\n    'Many profession quests have been added.',\n    'Various new recipes have been added. Many crafting professions should generally offer stronger options for both endgame and leveling content.',\n  ],\n}\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/index.ts",["1250"],"import dwarf from \"./race-changes/dwarf\";\nimport gnome from \"./race-changes/gnome\";\nimport human from \"./race-changes/human\";\nimport nightElf from \"./race-changes/night-elf\";\nimport orc from \"./race-changes/orc\";\nimport tauren from \"./race-changes/tauren\";\nimport troll from \"./race-changes/troll\";\nimport undead from \"./race-changes/undead\";\n\nexport default {\n  title: \"Race changes\",\n  content: [human, dwarf, gnome, nightElf, orc, troll, tauren, undead],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/classes/hunter-pets.ts",["1251"],"export default {\n  title: \"Hunter pets\",\n  content: [\n    \"Bears can now also learn Swipe, which deals mediocre damage in a frontal cone.\",\n    \"Crocolisks, Hyenas and Raptors can now learn Crushing Jaw, which has a 100% crit chance and 25 sec cooldown.\",\n    \"Spiders can now also learn Spider Poison, which has the same effect as Scorpid Poison.\",\n    \"Crabs can now also learn Shell Shield.\",\n    \"Tallstriders can now also learn Screech.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/class-changes/index.tsx",["1252"],"import druid from \"./classes/druid\";\nimport hunter from \"./classes/hunter\";\nimport hunterPets from \"./classes/hunter-pets\";\nimport mage from \"./classes/mage\";\nimport paladin from \"./classes/paladin\";\nimport priest from \"./classes/priest\";\nimport rogue from \"./classes/rogue\";\nimport shaman from \"./classes/shaman\";\nimport warlock from \"./classes/warlock\";\n// import warlockDemons from './classes/warlock-demons'\nimport warrior from \"./classes/warrior\";\n\nexport default {\n  title: \"Class changes\",\n  content: [\n    druid,\n    hunter,\n    hunterPets,\n    mage,\n    paladin,\n    priest,\n    rogue,\n    shaman,\n    warlock,\n    warrior,\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/restoration/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/arcane/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/frost/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/design-goals/index.tsx",["1253"],"export default {\n  title: \"Design goals\",\n  note: \"These suggested changes aim to improve diversity and give players additional ways to engage with the game. Some core design goals are listed below.\",\n  content: [\n    {\n      content: [\n        \"Diversity and variety! Expand on ways in which classes can be played, without changing them fundamentally.\",\n        \"Focus on class design and some QoL. Leave content, professions and itemization to people with better ideas.\",\n        \"Each spec should be great to have in a group, while none should be mandatory.\",\n        \"Each spec, and each race/class combination should have its place in both PvE and PvP.\",\n        \"Each spec gets something new. Some specs need more than others.\",\n        \"Healers should be more independent and able to grind mobs and resources more easily.\",\n        \"Adjust useless or boring talents and abilities.\",\n        \"All while staying true to the classic fantasy and mechanics and leaning into the uniqueness of each class and spec.\",\n      ],\n    },\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier6.tsx",["1254"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/marksmanship/tier3.tsx",["1255"],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier3.tsx",["1256"],{"ruleId":"1257","severity":1,"message":"1258","line":5,"column":8,"nodeType":"1259","messageId":"1260","endLine":5,"endColumn":16},{"ruleId":"1257","severity":1,"message":"1261","line":6,"column":8,"nodeType":"1259","messageId":"1260","endLine":6,"endColumn":19},{"ruleId":"1257","severity":1,"message":"1262","line":7,"column":8,"nodeType":"1259","messageId":"1260","endLine":7,"endColumn":19},{"ruleId":"1263","severity":1,"message":"1264","line":12,"column":1,"nodeType":"1265","endLine":23,"endColumn":3},{"ruleId":"1266","replacedBy":"1267"},{"ruleId":"1268","replacedBy":"1269"},{"ruleId":"1257","severity":1,"message":"1270","line":1,"column":8,"nodeType":"1259","messageId":"1260","endLine":1,"endColumn":13},{"ruleId":"1257","severity":1,"message":"1271","line":4,"column":8,"nodeType":"1259","messageId":"1260","endLine":4,"endColumn":21},{"ruleId":"1257","severity":1,"message":"1272","line":5,"column":8,"nodeType":"1259","messageId":"1260","endLine":5,"endColumn":18},{"ruleId":"1263","severity":1,"message":"1264","line":8,"column":1,"nodeType":"1265","endLine":11,"endColumn":3},{"ruleId":"1263","severity":1,"message":"1264","line":1,"column":1,"nodeType":"1265","endLine":20,"endColumn":3},{"ruleId":"1263","severity":1,"message":"1264","line":1,"column":1,"nodeType":"1265","endLine":13,"endColumn":3},{"ruleId":"1263","severity":1,"message":"1264","line":1,"column":1,"nodeType":"1265","endLine":11,"endColumn":2},{"ruleId":"1266","replacedBy":"1273"},{"ruleId":"1268","replacedBy":"1274"},{"ruleId":"1263","severity":1,"message":"1264","