-changes/undead.tsx",["1224"],"export default {\n  title: \"Undead\",\n  content: [\n    \"New ability: Embrace of Undeath: Deal 10% additional damage to targets below 10% health.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/assassination/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/mage/fire/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/combat/tier7.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunter/beast-mastery/tier4.ts",["1225"],"import { Talent } from '../../Classes'\nexport default [\n  null,\n  new Talent('Caretaker', 'ability_hunter_mendpet', ['Gives your Mend Pet spell a ', '% chance to remove 1 poison, disease, curse of magic effect from your pet each tick.'], 2, [[15, 30]]),\n  new Talent('Ferocity', 'inv_misc_monsterclaw_04', ['Increases the critical strike chance of your pets by ', '%.'], 5, [[3, 6, 9, 12, 15]], [{ x: null, y: null }], [{ x: 5, y: 2 }], null, null, null, null, ['D2']),\n  null,\n]\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/druid/feral-combat/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/restoration/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warrior/fury/tier2.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/hunt