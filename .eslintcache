t(\n    \"Fervor\",\n    \"ability_hunter_invigeration\",\n    [\"Intantly restores 100 focus to your pet.\"],\n    1,\n    [[]],\n    null,\n    null,\n    null,\n    null,\n    \"Instant\",\n    \"2 min cooldown\",\n    null,\n    { isNew: true, isChanged: false, isMoved: false }\n  ),\n  new Talent(\n    \"Unleashed Fury\",\n    \"ability_bullrush\",\n    [\"Increases the damage done by your pets by \", \"%.\"],\n    5,\n    [[4, 8, 12, 16, 20]]\n  ),\n  null,\n];\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/paladin/protection/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/shadow/tier1.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/App.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/components/nav-bar/index.tsx",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/patch-notes/race-changes/race-changes/troll.tsx",["1230"],"export default {\n  title: \"Troll\",\n  content: [\n    \"New ability: Da Voodoo Shuffle: Reduces the duration of all movement impairing effects by 15%.  Trolls be flippin' out mon!\",\n    \"Troll Regeneration now restores 1% health every 5 seconds.\",\n  ],\n};\n","/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/destruction/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/demonology/index.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/warlock/affliction/tier6.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/rogue/sublety/tier4.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/shaman/enhancement/tier3.ts",[],"/Users/djimovanberlo/Code/misc/tc-ts/src/data/talents/priest/holy/tier7.ts",[],"/User